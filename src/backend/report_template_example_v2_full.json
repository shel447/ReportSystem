{
  "id": "tpl_network_ops_full_v2_sample",
  "category": "ops_daily",
  "name": "网络运维日报模板（全量复杂示例）",
  "description": "覆盖 dynamic 参数、param_ref 串联、foreach、sql/nl2sql/ai_synthesis 以及 text/value/chart/simple_table/composite_table 展示类型。",
  "parameters": [
    {
      "id": "report_date",
      "label": "报告日期",
      "required": true,
      "input_type": "date",
      "interaction_mode": "form"
    },
    {
      "id": "regions",
      "label": "统计区域",
      "required": true,
      "input_type": "dynamic",
      "interaction_mode": "form",
      "multi": true,
      "source": "api:/network/regions",
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "on_unmapped": "error"
        }
      }
    },
    {
      "id": "focus_metric",
      "label": "重点指标",
      "required": true,
      "input_type": "enum",
      "interaction_mode": "chat",
      "options": [
        { "key": "alarm_count", "label": "告警量" },
        { "key": "availability", "label": "可用性" },
        { "key": "ticket_closure_rate", "label": "工单闭环率" }
      ],
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "map": {
            "alarm_count": "ALARM_COUNT",
            "availability": "AVAILABILITY",
            "ticket_closure_rate": "TICKET_CLOSURE_RATE"
          },
          "on_unmapped": "error"
        }
      }
    },
    {
      "id": "severity_levels",
      "label": "告警级别",
      "required": false,
      "input_type": "enum",
      "interaction_mode": "form",
      "multi": true,
      "options": [
        { "key": "critical", "label": "严重" },
        { "key": "major", "label": "重要" },
        { "key": "minor", "label": "一般" }
      ],
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "map": {
            "critical": "P1",
            "major": "P2",
            "minor": "P3"
          },
          "on_unmapped": "error"
        }
      }
    },
    {
      "id": "vendor",
      "label": "设备厂商",
      "required": false,
      "input_type": "dynamic",
      "interaction_mode": "chat",
      "source": "api:/inventory/vendors",
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "on_unmapped": "error"
        }
      }
    },
    {
      "id": "diagnosis_focus",
      "label": "诊断关注点",
      "required": false,
      "input_type": "free_text",
      "interaction_mode": "chat"
    }
  ],
  "sections": [
    {
      "title": "执行摘要",
      "description": "汇总核心运行态势与风险结论",
      "outline": {
        "requirement": "总结{report_date}在{@regions_ref}范围内的运行态势，重点指标{@metric_ref}。",
        "items": [
          {
            "id": "regions_ref",
            "type": "param_ref",
            "param_id": "regions",
            "hint": "统计区域"
          },
          {
            "id": "metric_ref",
            "type": "param_ref",
            "param_id": "focus_metric",
            "hint": "重点指标"
          }
        ]
      },
      "content": {
        "datasets": [
          {
            "id": "summary_sql",
            "source": {
              "kind": "sql",
              "query": "SELECT metric_code, metric_value FROM daily_ops_metrics WHERE biz_date = '{report_date}' AND region_code IN ('{@regions_ref.query}')"
            }
          },
          {
            "id": "health_nl2sql",
            "depends_on": [
              "summary_sql"
            ],
            "source": {
              "kind": "nl2sql",
              "description": "查询{report_date}在{@regions_ref.display}范围内按小时的网络健康趋势，重点围绕{@metric_ref.display}。"
            }
          },
          {
            "id": "risk_ai",
            "depends_on": [
              "summary_sql",
              "health_nl2sql"
            ],
            "source": {
              "kind": "ai_synthesis",
              "context": {
                "refs": [
                  "summary_sql",
                  "health_nl2sql"
                ],
                "queries": [
                  {
                    "id": "risk_query_1",
                    "query": "SELECT region_code, alarm_count, availability FROM daily_region_risk WHERE biz_date = '{report_date}' AND region_code IN ('{@regions_ref.query}')"
                  }
                ]
              },
              "prompt": "请结合已提供数据，输出{report_date}在{@regions_ref.display}范围内的风险结论与处置建议。重点指标：{@metric_ref.display}。额外关注：{diagnosis_focus}。"
            }
          }
        ],
        "presentation": {
          "type": "text",
          "template": "{report_date}，{@regions_ref.display}整体运行平稳。重点指标：{@metric_ref.display}。请关注风险摘要与处置建议。"
        }
      }
    },
    {
      "title": "区域逐项分析",
      "description": "对每个区域按统一结构输出细分分析",
      "foreach": {
        "param": "regions",
        "as": "region"
      },
      "outline": {
        "requirement": "针对{$region}输出关键指标值、趋势图、明细表和综合看板。",
        "items": [
          {
            "id": "region_item",
            "type": "free_text",
            "hint": "当前区域",
            "default": "{$region}"
          },
          {
            "id": "top_n",
            "type": "number",
            "hint": "Top数量",
            "default": "10"
          }
        ]
      },
      "subsections": [
        {
          "title": "区域关键指标值",
          "content": {
            "datasets": [
              {
                "id": "region_value_ds",
                "source": {
                  "kind": "sql",
                  "query": "SELECT availability AS value FROM daily_region_kpi WHERE biz_date = '{report_date}' AND region_code = '{$region}' LIMIT 1"
                }
              }
            ],
            "presentation": {
              "type": "value",
              "anchor": "{$value}"
            }
          }
        },
        {
          "title": "区域告警趋势图",
          "content": {
            "datasets": [
              {
                "id": "region_alarm_trend",
                "source": {
                  "kind": "nl2sql",
                  "description": "查询{report_date}当天{$region}的告警数量小时趋势。"
                }
              }
            ],
            "presentation": {
              "type": "chart",
              "dataset_id": "region_alarm_trend",
              "chart_type": "line"
            }
          }
        },
        {
          "title": "区域告警明细",
          "content": {
            "datasets": [
              {
                "id": "region_alarm_table",
                "source": {
                  "kind": "sql",
                  "query": "SELECT alarm_id, severity, site_name, first_seen_at FROM alarms WHERE biz_date = '{report_date}' AND region_code = '{$region}' ORDER BY first_seen_at DESC LIMIT {@top_n.query}"
                }
              }
            ],
            "presentation": {
              "type": "simple_table",
              "dataset_id": "region_alarm_table"
            }
          }
        },
        {
          "title": "区域综合看板",
          "content": {
            "datasets": [
              {
                "id": "region_kv_ds",
                "source": {
                  "kind": "sql",
                  "query": "SELECT total_sites, online_sites, alarm_count, ticket_closure_rate FROM region_daily_summary WHERE biz_date = '{report_date}' AND region_code = '{$region}' LIMIT 1"
                }
              },
              {
                "id": "region_vendor_ds",
                "depends_on": [
                  "region_kv_ds"
                ],
                "source": {
                  "kind": "sql",
                  "query": "SELECT vendor_name, alarm_count, availability FROM region_vendor_summary WHERE biz_date = '{report_date}' AND region_code = '{$region}' ORDER BY alarm_count DESC LIMIT {@top_n.query}"
                }
              }
            ],
            "presentation": {
              "type": "composite_table",
              "columns": 2,
              "sections": [
                {
                  "id": "kv_overview",
                  "dataset_id": "region_kv_ds",
                  "layout": {
                    "type": "kv_grid",
                    "cols_per_row": 2,
                    "fields": [
                      { "key": "区域", "value": "{$region}" },
                      { "key": "总站点数", "value": "{total_sites}" },
                      { "key": "在线站点数", "value": "{online_sites}" },
                      { "key": "告警总量", "value": "{alarm_count}" }
                    ]
                  }
                },
                {
                  "id": "vendor_breakdown",
                  "dataset_id": "region_vendor_ds",
                  "layout": {
                    "type": "tabular",
                    "headers": [
                      { "label": "厂商", "span": 1 },
                      { "label": "告警量", "span": 1 },
                      { "label": "可用性", "span": 1 }
                    ],
                    "columns": [
                      { "field": "vendor_name", "span": 1 },
                      { "field": "alarm_count", "span": 1 },
                      { "field": "availability", "span": 1 }
                    ]
                  }
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
