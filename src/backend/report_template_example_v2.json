{
  "id": "tpl_network_ops_daily_v2_sample",
  "category": "ops_daily",
  "name": "网络运维日报模板（参数映射示例）",
  "description": "示例模板：演示参数 value_mode/value_mapping 与 param_ref 串联。",
  "parameters": [
    {
      "id": "report_date",
      "label": "报告日期",
      "required": true,
      "input_type": "date",
      "interaction_mode": "form"
    },
    {
      "id": "region",
      "label": "统计区域",
      "required": true,
      "input_type": "dynamic",
      "interaction_mode": "form",
      "source": "api:/network/regions",
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "on_unmapped": "error"
        }
      }
    },
    {
      "id": "focus_metrics",
      "label": "重点指标",
      "required": true,
      "input_type": "enum",
      "interaction_mode": "chat",
      "multi": true,
      "options": [
        { "key": "alarm_count", "label": "告警量" },
        { "key": "availability", "label": "可用性" },
        { "key": "ticket_closure_rate", "label": "工单闭环率" }
      ],
      "value_mode": "key",
      "value_mapping": {
        "query": {
          "by": "key",
          "map": {
            "alarm_count": "ALARM_COUNT",
            "availability": "AVAILABILITY",
            "ticket_closure_rate": "TICKET_CLOSURE_RATE"
          },
          "on_unmapped": "error"
        }
      }
    }
  ],
  "sections": [
    {
      "title": "运行总览",
      "description": "展示区域级核心运行态势",
      "outline": {
        "requirement": "总结{@region_item}在{report_date}的运行态势，重点关注{@metric_item}。",
        "items": [
          {
            "id": "region_item",
            "type": "param_ref",
            "param_id": "region",
            "hint": "统计区域"
          },
          {
            "id": "metric_item",
            "type": "param_ref",
            "param_id": "focus_metrics",
            "hint": "重点指标"
          },
          {
            "id": "top_n",
            "type": "number",
            "hint": "TOP数量",
            "default": "5"
          }
        ]
      },
      "content": {
        "datasets": [
          {
            "id": "overview_metrics",
            "source": {
              "kind": "sql",
              "query": "SELECT metric_code, metric_value FROM daily_ops_metrics WHERE biz_date = '{report_date}' AND region_code = '{@region_item.query}'"
            }
          }
        ],
        "presentation": {
          "type": "text",
          "template": "{report_date}，{@region_item.display}整体运行平稳。重点关注：{@metric_item.display}。"
        }
      }
    }
  ]
}
