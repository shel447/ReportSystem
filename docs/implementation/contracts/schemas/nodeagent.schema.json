{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./nodeagent.schema.json",
  "title": "NodeAgent Configuration Consumer Contract",
  "description": "ReportSystem 启动时读取 NodeAgent 中 ChatBI 业务配置时使用的请求与响应协议。",
  "$defs": {
    "AppConfigRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["watch"],
      "properties": {"watch": {"const": "false"}}
    },
    "AppConfigResponse": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "chatbi": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "ai": {"type": "object", "additionalProperties": true},
            "knowledge": {"type": "object", "additionalProperties": true},
            "dataAnalysis": {"type": "object", "additionalProperties": true}
          }
        }
      }
    }
  }
}
