{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./nodeagent.schema.json",
  "title": "NodeAgent Configuration Consumer Contract",
  "description": "ReportSystem 周期读取 NodeAgent 应用配置快照时使用的请求与响应协议。",
  "$defs": {
    "AppConfigRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["watch"],
      "properties": {"watch": {"const": "false"}}
    },
    "AppConfigResponse": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "externalServices": {
          "type": "object",
          "additionalProperties": {"anyOf": [{"type": "object", "additionalProperties": true}, {}]}
        }
      }
    }
  }
}
