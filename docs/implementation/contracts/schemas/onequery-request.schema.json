{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./onequery-request.schema.json",
  "title": "OneQueryRequest",
  "description": "SQL 数据集统一查询请求。ReportSystem 将模板 SQL 渲染后提交给同源外部业务服务。",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "context"],
  "properties": {
    "query": {"type": "string", "minLength": 1},
    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "lineage.tracing.enable": {"type": "boolean"},
        "templateInstanceId": {"type": "string"},
        "sectionId": {"type": "string"},
        "datasetId": {"type": "string"}
      }
    }
  }
}
