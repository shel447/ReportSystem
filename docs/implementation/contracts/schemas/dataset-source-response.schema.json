{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./dataset-source-response.schema.json",
  "title": "DatasetSourceResponse",
  "description": "SQL 与 API 数据集共用的结构化查询响应。业务失败允许省略 data；成功响应直接返回字段元数据映射与数据行。",
  "type": "object",
  "additionalProperties": false,
  "required": ["retCode", "retInfo"],
  "properties": {
    "retCode": {"type": "integer"},
    "retInfo": {"type": "string"},
    "data": {
      "anyOf": [
        {"type": "null"},
        {"type": "object"}
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"retCode": {"const": 0}},
        "required": ["retCode"]
      },
      "then": {
        "required": ["data"],
        "properties": {
          "data": {"$ref": "#/$defs/Dataset"}
        }
      }
    }
  ],
  "$defs": {
    "Dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "results"],
      "properties": {
        "columns": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/ColumnMetadata"}
        },
        "results": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "ColumnMetadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "lineageTracing": {"$ref": "#/$defs/ColumnLineageTracing"}
      }
    },
    "ColumnLineageTracing": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sources"],
      "properties": {
        "type": {"type": "string"},
        "sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/ColumnLineageSource"}
        }
      }
    },
    "ColumnLineageSource": {
      "type": "object",
      "additionalProperties": true,
      "required": ["dataSourceName", "dataSourceType", "field", "businessName", "businessName_cn"],
      "properties": {
        "dataSourceName": {"type": "string"},
        "dataSourceType": {"type": "string"},
        "field": {"type": "string"},
        "businessName": {"type": "string"},
        "businessName_cn": {"type": "string"},
        "enumValues": {"type": "string"},
        "ui": {"type": "string"}
      }
    }
  }
}
