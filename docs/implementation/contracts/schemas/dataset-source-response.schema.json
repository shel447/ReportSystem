{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./dataset-source-response.schema.json",
  "title": "DatasetSourceResponse",
  "description": "SQL 与 API 数据集共用的结构化查询响应。首版 ReportSystem 消费第一个结果集。",
  "type": "object",
  "additionalProperties": false,
  "required": ["data"],
  "properties": {
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["results"],
      "properties": {
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/ResultSet"}
        }
      }
    }
  },
  "$defs": {
    "ResultSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "results"],
      "properties": {
        "columns": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "results": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
      }
    }
  }
}
