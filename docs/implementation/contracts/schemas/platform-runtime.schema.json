{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./platform-runtime.schema.json",
  "title": "Platform Runtime Consumer Contract",
  "$defs": {
    "NodeAgentAppConfigResponse": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "externalServices": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {"type": "object", "additionalProperties": true},
              {}
            ]
          }
        }
      }
    },
    "MetadataSyncResponse": {
      "type": "object",
      "additionalProperties": true,
      "anyOf": [
        {"required": ["version"]},
        {"required": ["process"]}
      ],
      "properties": {
        "version": {},
        "process": {}
      }
    }
  }
}
