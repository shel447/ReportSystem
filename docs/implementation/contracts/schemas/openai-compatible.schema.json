{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./openai-compatible.schema.json",
  "title": "OpenAI Compatible Consumer Contract",
  "description": "ReportSystem 使用的 OpenAI Compatible 请求与响应 fragment。",
  "$defs": {
    "Message": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role", "content"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "content": {}
      }
    },
    "ChatCompletionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "messages", "temperature"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "messages": {"type": "array", "items": {"$ref": "#/$defs/Message"}},
        "temperature": {"type": "number"},
        "max_tokens": {"type": "integer", "minimum": 1}
      }
    },
    "ChatCompletionResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["choices"],
      "properties": {
        "model": {"type": "string"},
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["message"],
            "properties": {
              "message": {
                "type": "object",
                "additionalProperties": true,
                "required": ["content"],
                "properties": {
                  "content": {
                    "anyOf": [
                      {"type": "string"},
                      {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": true,
                          "properties": {"text": {"type": "string"}}
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "EmbeddingRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "input"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "input": {"type": "array", "items": {"type": "string"}}
      }
    },
    "EmbeddingResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["data"],
      "properties": {
        "model": {"type": "string"},
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["embedding"],
            "properties": {
              "embedding": {"type": "array", "items": {"type": "number"}}
            }
          }
        }
      }
    }
  }
}
