{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guardrail-check.schema.json",
  "title": "Guardrail question or answer check response",
  "type": "object",
  "required": ["checkResults"],
  "properties": {
    "checkResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["isLegal"],
        "properties": {
          "isLegal": {"type": "boolean"},
          "response": {"type": "string"}
        }
      }
    }
  }
}
