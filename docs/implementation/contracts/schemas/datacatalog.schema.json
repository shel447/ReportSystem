{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./datacatalog.schema.json",
  "title": "DataCatalog Consumer Contract",
  "description": "ReportSystem 使用的 DataCatalog 请求与响应 fragment。逻辑实体与关系列表返回摘要，单详情分别引用严格 LogicalEntity 与 LogicalRelationship；数据集保持开放。",
  "$defs": {
    "ListLogicalEntitiesRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageSize", "pageNo", "filter"],
      "properties": {
        "pageSize": {"type": "integer", "minimum": 1},
        "pageNo": {"type": "integer", "minimum": 1},
        "filter": {"type": "object", "additionalProperties": true}
      }
    },
    "ListLogicalEntitiesResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["retCode", "data"],
      "properties": {
        "retCode": {"const": 0},
        "retInfo": {"type": "string"},
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["results"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": {"name": {"type": "string", "minLength": 1}}
              }
            },
            "totalCount": {"type": "integer"}
          }
        }
      }
    },
    "GetLogicalEntityRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logicalEntityName"],
      "properties": {"logicalEntityName": {"type": "string", "minLength": 1}}
    },
    "GetLogicalEntityResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["data"],
      "properties": {
        "data": {"$ref": "./logical-entity.schema.json"}
      }
    },
    "GetDatasetRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {"name": {"type": "string", "minLength": 1}}
    },
    "GetDatasetResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["data"],
      "properties": {
        "data": {"type": "object", "additionalProperties": true}
      }
    },
    "ListLogicalRelationsRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageSize", "pageNo", "filter"],
      "properties": {
        "pageSize": {"type": "integer", "minimum": 1},
        "pageNo": {"type": "integer", "minimum": 1},
        "filter": {"type": "object", "additionalProperties": true}
      }
    },
    "ListLogicalRelationsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["retCode", "data"],
      "properties": {
        "retCode": {"const": 0},
        "retInfo": {"type": "string"},
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["results"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": {"name": {"type": "string", "minLength": 1}}
              }
            },
            "totalCount": {"type": "integer"}
          }
        }
      }
    },
    "GetLogicalRelationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {"name": {"type": "string", "minLength": 1}}
    },
    "GetLogicalRelationResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["retCode", "data"],
      "properties": {
        "retCode": {"const": 0},
        "retInfo": {"type": "string"},
        "data": {"$ref": "./logical-relationship.schema.json"}
      }
    }
  }
}
