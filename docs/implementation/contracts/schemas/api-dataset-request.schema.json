{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./api-dataset-request.schema.json",
  "title": "ApiDatasetRequest",
  "description": "API 数据集统一请求。parameters 保存正式 ParameterValue 三元组，context 保存生成节点定位与查询选项。",
  "type": "object",
  "additionalProperties": false,
  "required": ["parameters", "context"],
  "properties": {
    "parameters": {
      "type": "object",
      "patternProperties": {
        "^[a-z][A-Za-z0-9]*$": {
          "type": "array",
          "items": {"$ref": "./report-template.schema.json#/$defs/ParameterValue"}
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["templateInstanceId", "sectionId", "datasetId"],
      "properties": {
        "lineage.tracing.enable": {"type": "boolean"},
        "templateInstanceId": {"type": "string"},
        "sectionId": {"type": "string"},
        "datasetId": {"type": "string"}
      }
    }
  }
}
