{
  "id": "tpl_network_daily",
  "category": "network_operations",
  "name": "网络运行日报",
  "description": "面向网络运维中心的统一日报模板。",
  "schemaVersion": "template.v3",
  "createdAt": "2026-04-18T09:00:00Z",
  "updatedAt": "2026-04-18T09:00:00Z",
  "parameters": [
    {
      "id": "report_date",
      "label": "报告日期",
      "description": "日报统计日期。",
      "inputType": "date",
      "required": true,
      "multi": false,
      "interactionMode": "form",
      "defaultValue": [
        {
          "label": "2026-04-18",
          "value": "2026-04-18",
          "query": "2026-04-18"
        }
      ],
      "priority": 0
    },
    {
      "id": "scope",
      "label": "分析对象",
      "description": "需要分析的网络对象。",
      "inputType": "dynamic",
      "required": true,
      "multi": true,
      "interactionMode": "natural_language",
      "source": "https://example.internal/api/network/scopes/options",
      "priority": 10
    }
  ],
  "catalogs": [
    {
      "id": "catalog_overview",
      "sections": [
        {
          "id": "section_overview",
          "outline": {
            "requirement": "分析{@scope_item}在{@report_date_item}的总体运行态势，并总结关键结论。",
            "items": [
              {
                "id": "scope_item",
                "label": "分析对象",
                "kind": "search_target",
                "required": true,
                "multi": true,
                "sourceParameterId": "scope",
                "widget": "multi_select"
              },
              {
                "id": "report_date_item",
                "label": "报告日期",
                "kind": "time_range",
                "required": true,
                "sourceParameterId": "report_date",
                "widget": "date"
              }
            ]
          },
          "content": {
            "datasets": [
              {
                "id": "dataset_daily_summary",
                "name": "运行概览数据集",
                "sourceType": "sql",
                "source": "SELECT stat_date, region_name, availability_rate, alarm_count, ticket_count\nFROM rpt_network_daily_summary\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_device_basic",
                "name": "核心设备基础信息数据集",
                "sourceType": "sql",
                "source": "SELECT device_name, model, vendor, site_name, online_time\nFROM dim_network_device\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_interface_checks",
                "name": "接口检查结果数据集",
                "sourceType": "sql",
                "source": "SELECT item, result, remark\nFROM rpt_network_interface_checks\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_board_checks",
                "name": "板卡检查结果数据集",
                "sourceType": "sql",
                "source": "SELECT item, result, remark\nFROM rpt_network_board_checks\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              }
            ],
            "presentation": {
              "kind": "mixed",
              "blocks": [
                {
                  "id": "block_summary_text",
                  "type": "text",
                  "title": "态势综述",
                  "properties": {
                    "template": "面向{$report_date}的{$scope}运行态势综述：可用率{#dataset_daily_summary.availability_rate}，告警数{#dataset_daily_summary.alarm_count}，工单数{#dataset_daily_summary.ticket_count}。"
                  }
                },
                {
                  "id": "block_summary_chart",
                  "type": "chart",
                  "title": "关键指标趋势",
                  "datasetId": "dataset_daily_summary",
                  "properties": {
                    "preferredType": "line"
                  }
                },
                {
                  "id": "block_summary_table",
                  "type": "table",
                  "title": "关键指标明细",
                  "datasetId": "dataset_daily_summary",
                  "properties": {
                    "showTitle": true,
                    "defaultDisplayRows": 10,
                    "columns": [
                      {
                        "key": "region_name",
                        "title": "范围"
                      },
                      {
                        "key": "availability_rate",
                        "title": "可用率"
                      },
                      {
                        "key": "alarm_count",
                        "title": "告警数"
                      }
                    ],
                    "mergeColumns": [
                      {
                        "title": "范围指标",
                        "columns": [
                          "region_name",
                          "availability_rate"
                        ]
                      }
                    ],
                    "mergeRows": [
                      {
                        "column": "region_name"
                      }
                    ]
                  }
                },
                {
                  "id": "block_device_inspection",
                  "type": "composite_table",
                  "title": "核心设备巡检信息",
                  "parts": [
                    {
                      "id": "part_basic_info",
                      "title": "基础信息",
                      "sourceType": "query",
                      "datasetId": "dataset_device_basic",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true,
                        "showTitle": true,
                        "defaultDisplayRows": 8
                      }
                    },
                    {
                      "id": "part_interface_checks",
                      "title": "接口检查结果",
                      "sourceType": "query",
                      "datasetId": "dataset_interface_checks",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true,
                        "showTitle": true,
                        "defaultDisplayRows": 8,
                        "columns": [
                          {
                            "key": "item",
                            "title": "检查项"
                          },
                          {
                            "key": "result",
                            "title": "结果"
                          },
                          {
                            "key": "remark",
                            "title": "备注"
                          }
                        ],
                        "mergeColumns": [
                          {
                            "title": "检查结论",
                            "columns": [
                              "result",
                              "remark"
                            ]
                          }
                        ],
                        "mergeRows": [
                          {
                            "column": "item",
                            "mode": "default"
                          }
                        ]
                      }
                    },
                    {
                      "id": "part_board_checks",
                      "title": "板卡检查结果",
                      "sourceType": "query",
                      "datasetId": "dataset_board_checks",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true,
                        "showTitle": true,
                        "defaultDisplayRows": 8,
                        "columns": [
                          {
                            "key": "item",
                            "title": "检查项"
                          },
                          {
                            "key": "result",
                            "title": "结果"
                          },
                          {
                            "key": "remark",
                            "title": "备注"
                          }
                        ]
                      }
                    },
                    {
                      "id": "part_inspection_summary",
                      "title": "巡检问题及建议",
                      "sourceType": "summary",
                      "summarySpec": {
                        "partIds": [
                          "part_interface_checks",
                          "part_board_checks"
                        ],
                        "rows": [
                          {
                            "id": "major_issue",
                            "title": "主要问题"
                          },
                          {
                            "id": "risk_assessment",
                            "title": "影响评估"
                          },
                          {
                            "id": "action_advice",
                            "title": "处理建议"
                          }
                        ],
                        "prompt": "基于前序检查结果，从各行对应角度填写总结。"
                      }
                    }
                  ]
                }
              ]
            }
          }
        }
      ],
      "title": "运行概览"
    },
    {
      "id": "catalog_scope_case_strategy",
      "title": "{$scope} 分支分析",
      "dynamic": {
        "type": "foreachCase",
        "parameterId": "scope",
        "as": "scope_item",
        "cases": [
          {
            "id": "hq_network_case",
            "values": [
              "hq-network"
            ],
            "sections": [
              {
                "id": "section_hq_network_strategy",
                "outline": {
                  "requirement": "分析总部网络的核心链路与集中管控风险。",
                  "items": []
                },
                "content": {
                  "presentation": {
                    "kind": "text",
                    "blocks": [
                      {
                        "id": "block_hq_network_strategy",
                        "type": "text",
                        "properties": {
                          "template": "{$scope} 需要重点关注核心链路容量、跨区域访问质量和统一管控风险。"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          },
          {
            "id": "branch_network_case",
            "values": [
              "branch-network"
            ],
            "sections": [
              {
                "id": "section_branch_network_strategy",
                "outline": {
                  "requirement": "分析分支网络的接入质量与本地故障风险。",
                  "items": []
                },
                "content": {
                  "presentation": {
                    "kind": "text",
                    "blocks": [
                      {
                        "id": "block_branch_network_strategy",
                        "type": "text",
                        "properties": {
                          "template": "{$scope} 需要重点关注接入链路稳定性、末端设备告警和本地恢复能力。"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        ],
        "defaultCase": {
          "sections": [
            {
              "id": "section_scope_default_strategy",
              "outline": {
                "requirement": "分析当前对象的通用运行风险。",
                "items": []
              },
              "content": {
                "presentation": {
                  "kind": "text",
                  "blocks": [
                    {
                      "id": "block_scope_default_strategy",
                      "type": "text",
                      "properties": {
                        "template": "{$scope} 按通用网络对象规则进行运行风险分析。"
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": "catalog_scope_analysis",
      "dynamic": {
        "type": "foreach",
        "parameterId": "scope",
        "as": "scope_item"
      },
      "parameters": [
        {
          "id": "detail_granularity",
          "label": "分析粒度",
          "description": "该目录下章节共享的分析粒度。",
          "inputType": "enum",
          "required": true,
          "multi": false,
          "interactionMode": "form",
          "options": [
            {
              "label": "小时",
              "value": "hour",
              "query": "hour"
            },
            {
              "label": "天",
              "value": "day",
              "query": "day"
            }
          ],
          "defaultValue": [
            {
              "label": "天",
              "value": "day",
              "query": "day"
            }
          ],
          "priority": 20
        }
      ],
      "subCatalogs": [
        {
          "id": "catalog_scope_availability",
          "sections": [
            {
              "id": "section_scope_trend",
              "parameters": [
                {
                  "id": "trend_window",
                  "label": "趋势窗口",
                  "description": "仅用于该章节的趋势窗口。",
                  "inputType": "enum",
                  "required": true,
                  "multi": false,
                  "interactionMode": "form",
                  "options": [
                    {
                      "label": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    },
                    {
                      "label": "最近30天",
                      "value": "30d",
                      "query": "30d"
                    }
                  ],
                  "defaultValue": [
                    {
                      "label": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    }
                  ],
                  "priority": 99
                }
              ],
              "outline": {
                "requirement": "分析{@scope_item}在{@report_date_item}的可用性{$detail_granularity}趋势，并结合{$trend_window}给出结论。",
                "items": [
                  {
                    "id": "scope_item",
                    "label": "分析对象",
                    "kind": "search_target",
                    "required": true,
                    "sourceParameterId": "scope",
                    "widget": "select"
                  },
                  {
                    "id": "report_date_item",
                    "label": "报告日期",
                    "kind": "time_range",
                    "required": true,
                    "sourceParameterId": "report_date",
                    "widget": "date"
                  }
                ]
              },
              "content": {
                "datasets": [
                  {
                    "id": "dataset_scope_trend",
                    "name": "对象趋势数据集",
                    "sourceType": "sql",
                    "source": "SELECT stat_date, scope_code, availability_rate\nFROM rpt_network_scope_trend\nWHERE stat_date BETWEEN DATE_SUB('{{reportDate}}', INTERVAL 30 DAY) AND '{{reportDate}}'\n  AND scope_code = '{{scope}}'"
                  }
                ],
                "presentation": {
                  "kind": "mixed",
                  "blocks": [
                    {
                      "id": "block_scope_trend_chart",
                      "type": "chart",
                      "title": "趋势图",
                      "datasetId": "dataset_scope_trend"
                    },
                    {
                      "id": "block_scope_trend_text",
                      "type": "text",
                      "title": "趋势结论",
                      "properties": {
                        "template": "{$scope}在{$report_date}的可用性趋势结论：首条趋势日期{#dataset_scope_trend.stat_date}，可用率{#dataset_scope_trend.availability_rate}。"
                      }
                    }
                  ]
                }
              }
            }
          ],
          "title": "{$scope}可用性分析"
        }
      ],
      "title": "{$scope}专题分析"
    },
    {
      "id": "catalog_external_deep_dive",
      "title": "{$scope}外部专题分析",
      "dynamic": {
        "type": "custom",
        "url": "https://report-content.example.com/api/report/catalog"
      }
    },
    {
      "id": "catalog_external_sections",
      "title": "外部章节示例",
      "sections": [
        {
          "id": "section_external_recommendation",
          "dynamic": {
            "type": "custom",
            "url": "https://report-content.example.com/api/report/section"
          },
          "outline": {
            "requirement": "基于{$scope}在{$report_date}的运行数据生成外部分析建议。",
            "items": []
          }
        }
      ]
    }
  ]
}
