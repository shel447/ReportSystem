{
  "id": "tpl_network_daily",
  "category": "network_operations",
  "name": "网络运行日报",
  "description": "面向网络运维中心的统一日报模板。",
  "schemaVersion": "template.v3",
  "tags": [
    "daily",
    "network",
    "operations"
  ],
  "createdAt": "2026-04-18T09:00:00Z",
  "updatedAt": "2026-04-18T09:00:00Z",
  "parameters": [
    {
      "id": "report_date",
      "label": "报告日期",
      "description": "日报统计日期。",
      "inputType": "date",
      "required": true,
      "multi": false,
      "interactionMode": "form",
      "defaultValue": [
        {
          "label": "2026-04-18",
          "value": "2026-04-18",
          "query": "2026-04-18"
        }
      ]
    },
    {
      "id": "scope",
      "label": "分析对象",
      "description": "需要分析的网络对象。",
      "inputType": "dynamic",
      "required": true,
      "multi": true,
      "interactionMode": "natural_language",
      "source": "https://example.internal/api/network/scopes/options"
    }
  ],
  "catalogs": [
    {
      "id": "catalog_overview",
      "sections": [
        {
          "id": "section_overview",
          "outline": {
            "requirement": "分析{@scope_item}在{@report_date_item}的总体运行态势，并总结关键结论。",
            "items": [
              {
                "id": "scope_item",
                "label": "分析对象",
                "kind": "search_target",
                "required": true,
                "multi": true,
                "sourceParameterId": "scope",
                "widget": "multi_select"
              },
              {
                "id": "report_date_item",
                "label": "报告日期",
                "kind": "time_range",
                "required": true,
                "sourceParameterId": "report_date",
                "widget": "date"
              }
            ]
          },
          "content": {
            "datasets": [
              {
                "id": "dataset_daily_summary",
                "name": "运行概览数据集",
                "sourceType": "sql",
                "source": "SELECT stat_date, region_name, availability_rate, alarm_count, ticket_count\nFROM rpt_network_daily_summary\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_device_basic",
                "name": "核心设备基础信息数据集",
                "sourceType": "sql",
                "source": "SELECT device_name, model, vendor, site_name, online_time\nFROM dim_network_device\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_interface_checks",
                "name": "接口检查结果数据集",
                "sourceType": "sql",
                "source": "SELECT item, result, remark\nFROM rpt_network_interface_checks\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              },
              {
                "id": "dataset_board_checks",
                "name": "板卡检查结果数据集",
                "sourceType": "sql",
                "source": "SELECT item, result, remark\nFROM rpt_network_board_checks\nWHERE stat_date = '{{reportDate}}'\n  AND scope_code IN ({{scope}})"
              }
            ],
            "presentation": {
              "kind": "mixed",
              "blocks": [
                {
                  "id": "block_summary_text",
                  "type": "paragraph",
                  "title": "态势综述",
                  "datasetId": "dataset_daily_summary"
                },
                {
                  "id": "block_summary_chart",
                  "type": "chart",
                  "title": "关键指标趋势",
                  "datasetId": "dataset_daily_summary"
                },
                {
                  "id": "block_summary_table",
                  "type": "table",
                  "title": "关键指标明细",
                  "datasetId": "dataset_daily_summary",
                  "properties": {
                    "mergeColumns": [
                      {
                        "title": "范围指标",
                        "columns": [
                          "scope_name",
                          "metric_name"
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "block_device_inspection",
                  "type": "composite_table",
                  "title": "核心设备巡检信息",
                  "parts": [
                    {
                      "id": "part_basic_info",
                      "title": "基础信息",
                      "sourceType": "query",
                      "datasetId": "dataset_device_basic",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true
                      }
                    },
                    {
                      "id": "part_interface_checks",
                      "title": "接口检查结果",
                      "sourceType": "query",
                      "datasetId": "dataset_interface_checks",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true,
                        "columns": [
                          {
                            "key": "item",
                            "title": "检查项"
                          },
                          {
                            "key": "result",
                            "title": "结果"
                          },
                          {
                            "key": "remark",
                            "title": "备注"
                          }
                        ],
                        "mergeColumns": [
                          {
                            "title": "检查结论",
                            "columns": [
                              "result",
                              "remark"
                            ]
                          }
                        ]
                      }
                    },
                    {
                      "id": "part_board_checks",
                      "title": "板卡检查结果",
                      "sourceType": "query",
                      "datasetId": "dataset_board_checks",
                      "tableLayout": {
                        "kind": "table",
                        "showHeader": true,
                        "columns": [
                          {
                            "key": "item",
                            "title": "检查项"
                          },
                          {
                            "key": "result",
                            "title": "结果"
                          },
                          {
                            "key": "remark",
                            "title": "备注"
                          }
                        ]
                      }
                    },
                    {
                      "id": "part_inspection_summary",
                      "title": "巡检问题及建议",
                      "sourceType": "summary",
                      "summarySpec": {
                        "partIds": [
                          "part_interface_checks",
                          "part_board_checks"
                        ],
                        "rows": [
                          {
                            "id": "major_issue",
                            "title": "主要问题"
                          },
                          {
                            "id": "risk_assessment",
                            "title": "影响评估"
                          },
                          {
                            "id": "action_advice",
                            "title": "处理建议"
                          }
                        ],
                        "prompt": "基于前序检查结果，从各行对应角度填写总结。"
                      }
                    }
                  ]
                }
              ]
            }
          }
        }
      ],
      "title": "运行概览"
    },
    {
      "id": "catalog_scope_analysis",
      "foreach": {
        "parameterId": "scope",
        "as": "scope_item"
      },
      "parameters": [
        {
          "id": "detail_granularity",
          "label": "分析粒度",
          "description": "该目录下章节共享的分析粒度。",
          "inputType": "enum",
          "required": true,
          "multi": false,
          "interactionMode": "form",
          "options": [
            {
              "label": "小时",
              "value": "hour",
              "query": "hour"
            },
            {
              "label": "天",
              "value": "day",
              "query": "day"
            }
          ],
          "defaultValue": [
            {
              "label": "天",
              "value": "day",
              "query": "day"
            }
          ]
        }
      ],
      "subCatalogs": [
        {
          "id": "catalog_scope_availability",
          "sections": [
            {
              "id": "section_scope_trend",
              "parameters": [
                {
                  "id": "trend_window",
                  "label": "趋势窗口",
                  "description": "仅用于该章节的趋势窗口。",
                  "inputType": "enum",
                  "required": true,
                  "multi": false,
                  "interactionMode": "form",
                  "options": [
                    {
                      "label": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    },
                    {
                      "label": "最近30天",
                      "value": "30d",
                      "query": "30d"
                    }
                  ],
                  "defaultValue": [
                    {
                      "label": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    }
                  ]
                }
              ],
              "outline": {
                "requirement": "分析{@scope_item}在{@report_date_item}的可用性{$detail_granularity}趋势，并结合{$trend_window}给出结论。",
                "items": [
                  {
                    "id": "scope_item",
                    "label": "分析对象",
                    "kind": "search_target",
                    "required": true,
                    "sourceParameterId": "scope",
                    "widget": "select"
                  },
                  {
                    "id": "report_date_item",
                    "label": "报告日期",
                    "kind": "time_range",
                    "required": true,
                    "sourceParameterId": "report_date",
                    "widget": "date"
                  }
                ]
              },
              "content": {
                "datasets": [
                  {
                    "id": "dataset_scope_trend",
                    "name": "对象趋势数据集",
                    "sourceType": "sql",
                    "source": "SELECT stat_date, scope_code, availability_rate\nFROM rpt_network_scope_trend\nWHERE stat_date BETWEEN DATE_SUB('{{reportDate}}', INTERVAL 30 DAY) AND '{{reportDate}}'\n  AND scope_code = '{{scope}}'"
                  }
                ],
                "presentation": {
                  "kind": "mixed",
                  "blocks": [
                    {
                      "id": "block_scope_trend_chart",
                      "type": "chart",
                      "title": "趋势图",
                      "datasetId": "dataset_scope_trend"
                    },
                    {
                      "id": "block_scope_trend_text",
                      "type": "paragraph",
                      "title": "趋势结论",
                      "datasetId": "dataset_scope_trend"
                    }
                  ]
                }
              }
            }
          ],
          "title": "{$scope}可用性分析"
        }
      ],
      "title": "{$scope}专题分析"
    }
  ]
}
