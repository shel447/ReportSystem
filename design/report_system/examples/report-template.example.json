{
  "id": "tpl_network_daily",
  "category": "network_operations",
  "name": "网络运行日报",
  "description": "面向网络运维中心的统一日报模板。",
  "schemaVersion": "template.v3",
  "tags": [
    "daily",
    "network",
    "operations"
  ],
  "createdAt": "2026-04-18T09:00:00Z",
  "updatedAt": "2026-04-18T09:00:00Z",
  "parameters": [
    {
      "id": "report_date",
      "label": "报告日期",
      "description": "日报统计日期。",
      "inputType": "date",
      "required": true,
      "multi": false,
      "interactionMode": "form",
      "valueMode": "value",
      "defaultValue": [
        {
          "display": "2026-04-18",
          "value": "2026-04-18",
          "query": "2026-04-18"
        }
      ]
    },
    {
      "id": "scope",
      "label": "分析对象",
      "description": "需要分析的网络对象。",
      "inputType": "dynamic",
      "required": true,
      "multi": true,
      "interactionMode": "natural_language",
      "valueMode": "query",
      "openSource": {
        "url": "https://example.internal/api/network/scopes/options"
      }
    }
  ],
  "catalogs": [
    {
      "id": "catalog_overview",
      "name": "运行概览",
      "sections": [
        {
          "id": "section_overview",
          "title": "总体态势",
          "outline": {
            "requirement": "分析{@scope_item}在{@report_date_item}的总体运行态势，并总结关键结论。",
            "items": [
              {
                "id": "scope_item",
                "label": "分析对象",
                "kind": "search_target",
                "required": true,
                "multi": true,
                "sourceParameterId": "scope",
                "widget": "multi_select"
              },
              {
                "id": "report_date_item",
                "label": "报告日期",
                "kind": "time_range",
                "required": true,
                "sourceParameterId": "report_date",
                "widget": "date"
              }
            ]
          },
          "content": {
            "datasets": [
              {
                "id": "dataset_daily_summary",
                "name": "运行概览数据集",
                "sourceType": "sql",
                "sourceRef": "sql.network.daily_summary"
              }
            ],
            "presentation": {
              "kind": "mixed",
              "blocks": [
                {
                  "id": "block_summary_text",
                  "type": "paragraph",
                  "title": "态势综述",
                  "datasetId": "dataset_daily_summary"
                },
                {
                  "id": "block_summary_chart",
                  "type": "chart",
                  "title": "关键指标趋势",
                  "datasetId": "dataset_daily_summary"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "catalog_scope_analysis",
      "name": "对象分析",
      "nameTemplate": "{$scope}专题分析",
      "foreach": {
        "parameterId": "scope",
        "as": "scope_item"
      },
      "parameters": [
        {
          "id": "detail_granularity",
          "label": "分析粒度",
          "description": "该目录下章节共享的分析粒度。",
          "inputType": "enum",
          "required": true,
          "multi": false,
          "interactionMode": "form",
          "valueMode": "value",
          "options": [
            {
              "display": "小时",
              "value": "hour",
              "query": "hour"
            },
            {
              "display": "天",
              "value": "day",
              "query": "day"
            }
          ],
          "defaultValue": [
            {
              "display": "天",
              "value": "day",
              "query": "day"
            }
          ]
        }
      ],
      "subCatalogs": [
        {
          "id": "catalog_scope_availability",
          "name": "可用性分析",
          "nameTemplate": "{$scope}可用性分析",
          "sections": [
            {
              "id": "section_scope_trend",
              "title": "可用性趋势",
              "titleTemplate": "{$scope}可用性{$detail_granularity}趋势",
              "parameters": [
                {
                  "id": "trend_window",
                  "label": "趋势窗口",
                  "description": "仅用于该章节的趋势窗口。",
                  "inputType": "enum",
                  "required": true,
                  "multi": false,
                  "interactionMode": "form",
                  "valueMode": "value",
                  "options": [
                    {
                      "display": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    },
                    {
                      "display": "最近30天",
                      "value": "30d",
                      "query": "30d"
                    }
                  ],
                  "defaultValue": [
                    {
                      "display": "最近7天",
                      "value": "7d",
                      "query": "7d"
                    }
                  ]
                }
              ],
              "outline": {
                "requirement": "分析{@scope_item}在{@report_date_item}的可用性{$detail_granularity}趋势，并结合{$trend_window}给出结论。",
                "items": [
                  {
                    "id": "scope_item",
                    "label": "分析对象",
                    "kind": "search_target",
                    "required": true,
                    "sourceParameterId": "scope",
                    "widget": "select"
                  },
                  {
                    "id": "report_date_item",
                    "label": "报告日期",
                    "kind": "time_range",
                    "required": true,
                    "sourceParameterId": "report_date",
                    "widget": "date"
                  }
                ]
              },
              "content": {
                "datasets": [
                  {
                    "id": "dataset_scope_trend",
                    "name": "对象趋势数据集",
                    "sourceType": "sql",
                    "sourceRef": "sql.network.scope_trend"
                  }
                ],
                "presentation": {
                  "kind": "mixed",
                  "blocks": [
                    {
                      "id": "block_scope_trend_chart",
                      "type": "chart",
                      "title": "趋势图",
                      "datasetId": "dataset_scope_trend"
                    },
                    {
                      "id": "block_scope_trend_text",
                      "type": "paragraph",
                      "title": "趋势结论",
                      "datasetId": "dataset_scope_trend"
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
