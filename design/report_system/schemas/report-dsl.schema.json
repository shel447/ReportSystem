{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/report.schema.json",
  "title": "Report",
  "description": "根据提供的 DSL 类型定义生成的 Report 根对象 JSON Schema",
  "type": "object",
  "properties": {
    "basicInfo": {
      "$ref": "#/$defs/BasicInfo"
    },
    "cover": {
      "$ref": "#/$defs/Cover"
    },
    "signaturePage": {
      "$ref": "#/$defs/SignaturePage"
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Catalog"
      }
    },
    "summary": {
      "$ref": "#/$defs/ReportSummary"
    },
    "reportMeta": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/GenerateMeta"
      }
    },
    "layout": {
      "$ref": "#/$defs/PageLayout"
    }
  },
  "required": [
    "basicInfo",
    "catalogs",
    "layout"
  ],
  "additionalProperties": false,
  "$defs": {
    "Status": {
      "type": "string",
      "enum": [
        "Running",
        "Success",
        "Aborted",
        "Failed"
      ]
    },
    "LayoutType": {
      "type": "string",
      "enum": [
        "grid",
        "flow",
        "absolute"
      ]
    },
    "FieldType": {
      "type": "string",
      "enum": [
        "string",
        "long",
        "int",
        "timestamp",
        "double",
        "float",
        "enum"
      ]
    },
    "AdditionalInfoType": {
      "type": "string",
      "enum": [
        "Prompt",
        "Summary",
        "SQL",
        "API",
        "Knowledge"
      ]
    },
    "ValueFormat": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "time"
            },
            "format": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "format"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "percentage"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "number"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "byte"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        }
      ]
    },
    "UIEvent": {
      "type": "object",
      "properties": {
        "trigger": {
          "type": "string",
          "enum": [
            "click",
            "dblclick",
            "hover"
          ]
        },
        "name": {
          "type": "string"
        },
        "dependency": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "trigger",
        "name",
        "dependency"
      ],
      "additionalProperties": false
    },
    "FieldUI": {
      "type": "object",
      "properties": {
        "displayPriority": {
          "type": "string",
          "enum": [
            "high",
            "normal",
            "never"
          ]
        },
        "valueFormat": {
          "$ref": "#/$defs/ValueFormat"
        },
        "event": {
          "$ref": "#/$defs/UIEvent"
        }
      },
      "additionalProperties": false
    },
    "EnumValue": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "title"
      ],
      "additionalProperties": false
    },
    "Column": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/FieldType"
        },
        "enumConfig": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EnumValue"
          }
        },
        "uiConfig": {
          "$ref": "#/$defs/FieldUI"
        },
        "colSpan": {
          "type": "number"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Column"
          }
        }
      },
      "required": [
        "title",
        "key"
      ],
      "additionalProperties": false
    },
    "MergeColumnInfo": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "columns"
      ],
      "additionalProperties": false
    },
    "MergeRowConfig": {
      "type": "object",
      "properties": {
        "startRowIndex": {
          "type": "number"
        },
        "rowSpan": {
          "type": "number"
        },
        "columnKey": {
          "type": "string"
        },
        "mergedText": {
          "type": "string"
        }
      },
      "required": [
        "startRowIndex",
        "rowSpan",
        "columnKey"
      ],
      "additionalProperties": false
    },
    "GridLayout": {
      "type": "object",
      "properties": {
        "type": {
          "const": "grid"
        },
        "gx": {
          "type": "number"
        },
        "gy": {
          "type": "number"
        },
        "gw": {
          "type": "number"
        },
        "gh": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "gx",
        "gy",
        "gw",
        "gh"
      ],
      "additionalProperties": false
    },
    "FlowLayout": {
      "type": "object",
      "properties": {
