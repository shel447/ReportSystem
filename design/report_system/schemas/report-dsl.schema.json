    },
    "AbsoluteLayout": {
      "type": "object",
      "properties": {
        "type": {
          "const": "absolute"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        },
        "zIndex": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "x",
        "y",
        "w",
        "h"
      ],
      "additionalProperties": false
    },
    "ComponentLayout": {
      "oneOf": [
        {
          "$ref": "#/$defs/GridLayout"
        },
        {
          "$ref": "#/$defs/FlowLayout"
        },
        {
          "$ref": "#/$defs/AbsoluteLayout"
        }
      ]
