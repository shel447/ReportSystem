            "filter",
            "jump",
            "highlight"
          ]
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "componentId",
        "type"
      ],
      "additionalProperties": false
    },
    "Interaction": {
      "type": "object",
      "properties": {
        "trigger": {
          "$ref": "#/$defs/InteractionTrigger"
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InteractionTarget"
          }
        }
      },
      "required": [
        "trigger",
        "targets"
      ],
      "additionalProperties": false
    },
    "TextDataProperty": {
      "type": "object",
