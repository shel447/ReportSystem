        "sourceId": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "autoRefresh": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      },
      "required": [
        "dataType",
        "content"
      ],
      "additionalProperties": false
    },
    "TableDataProperty": {
