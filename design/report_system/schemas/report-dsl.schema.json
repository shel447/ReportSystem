{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/report-dsl.schema.json",
  "title": "Report",
  "description": "报告 DSL JSON Schema。保持单一 Report 根对象，顶层公共属性复用；通过 structureType 区分瀑布流结构与分页/PPT结构。structureType 缺省时按 flow 兼容处理。本版本在不改变顶层属性定义的前提下，补齐 BI Engine TypeScript 模型中已有而 schema 内部缺失的字段。",
  "type": "object",
  "properties": {
    "structureType": {
      "type": "string",
      "enum": [
        "flow",
        "paged"
      ],
      "default": "flow",
      "description": "报告结构类型。flow 表示瀑布流报告，使用 catalogs + layout；paged 表示分页/PPT报告，使用 content。未声明时按 flow 处理。"
    },
    "basicInfo": {
      "$ref": "#/$defs/BasicInfo"
    },
    "cover": {
      "$ref": "#/$defs/Cover"
    },
    "backCover": {
      "$ref": "#/$defs/BackCoverConfig",
      "description": "PPT/分页报告封底配置。与 BI Engine PPT.backCover 对齐；structureType=paged 时使用。"
    },
    "signaturePage": {
      "$ref": "#/$defs/SignaturePage"
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Catalog"
      },
      "description": "瀑布流报告主体目录。structureType=flow 或缺省时使用。"
    },
    "summary": {
      "$ref": "#/$defs/ReportSummary"
    },
    "reportMeta": {
      "$ref": "#/$defs/ReportMeta"
    },
    "layout": {
      "$ref": "#/$defs/PageLayout"
    },
    "content": {
      "$ref": "#/$defs/PagedContent",
      "description": "分页/PPT报告主体内容。structureType=paged 时使用。可以是 Slide[] 或 SlideSection[]。"
    }
  },
  "required": [
    "basicInfo"
  ],
  "allOf": [
    {
      "if": {
        "required": [
          "structureType"
        ],
        "properties": {
          "structureType": {
            "const": "paged"
          }
        }
      },
      "then": {
        "required": [
          "content"
        ],
        "not": {
          "required": [
            "catalogs"
          ]
        }
      },
      "else": {
        "required": [
          "catalogs",
          "layout"
        ],
        "not": {
          "required": [
            "content"
          ]
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "PagedContent": {
      "description": "PPT 内容。允许没有显式分节时直接使用 Slide[]；有分节时使用 SlideSection[]。不建议在同一数组内混放 Slide 与 SlideSection。",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Slide"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SlideSection"
          }
        }
      ]
    },
    "Slide": {
      "type": "object",
      "description": "幻灯片单一页面。页面内组件直接复用 BIEngineComponent。",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "layout": {
          "$ref": "#/$defs/PageLayout"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BIEngineComponent"
          }
        }
      },
      "required": [
        "id",
        "layout",
        "components"
      ],
      "additionalProperties": false
    },
    "SlideSection": {
      "type": "object",
      "description": "幻灯片节/分组。用于表示 PPT 中的一组 slides。",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "section"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "slides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Slide"
          }
        }
      },
      "required": [
        "id",
        "type",
        "slides"
      ],
      "additionalProperties": false
    },
    "BackCoverConfig": {
      "type": "object",
      "description": "PPT 封底配置。与 BI Engine BackCoverConfig 对齐。",
      "properties": {
        "image": {
          "type": "string",
          "description": "背景图片，支持 URL 或 base64。"
        },
        "text": {
          "type": "string",
          "description": "封底显示文本，默认可由渲染端处理为 Thank You。"
        }
      },
      "additionalProperties": false
    },
    "ReportMeta": {
      "type": "object",
      "description": "报告生成元数据。key 通常通过目录、章节、页面或组件 id 匹配。",
      "additionalProperties": {
        "$ref": "#/$defs/GenerateMeta"
      }
    },
    "Status": {
      "type": "string",
      "enum": [
        "Running",
        "Success",
        "Aborted",
        "Failed"
      ]
    },
    "LayoutType": {
      "type": "string",
      "enum": [
        "grid",
        "flow",
        "absolute"
      ]
    },
    "CoverLayoutType": {
      "type": "string",
      "enum": [
        "TITLE_TOP",
        "TITLE_CENTER"
      ]
    },
    "FieldType": {
      "type": "string",
      "enum": [
        "string",
        "long",
        "int",
        "timestamp",
        "double",
        "float",
        "enum"
      ]
    },
    "AdditionalInfoType": {
      "type": "string",
      "enum": [
        "Prompt",
        "Summary",
        "SQL",
        "API",
        "Knowledge"
      ]
    },
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "ParameterValue": {
      "type": "object",
      "properties": {
        "label": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      },
      "required": [
        "label",
        "value",
        "query"
      ],
      "additionalProperties": false
    },
    "Parameter": {
      "type": "object",
      "description": "Report DSL 生成元数据参数定义。与 BI Engine Parameter 对齐，不复用模板参数结构。",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "widget": {
          "type": "string",
          "enum": [
            "select",
            "multi_select",
            "date",
            "input"
          ]
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterOption"
          }
        }
      },
      "required": [
        "id",
        "label",
        "required",
        "widget"
      ],
      "additionalProperties": false
    },
    "BasicInfo": {
      "type": "object",
      "description": "报告基础信息。保留 parameters 以支持已生成报告的结构化编辑；补齐 BI Engine 模型中的资产基础字段。",
      "properties": {
        "id": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string",
          "const": "1.0.0"
        },
        "mode": {
          "type": "string",
          "enum": [
            "draft",
            "published"
          ]
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subTitle": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "templateId": {
          "type": "string"
        },
        "templateName": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "createDate": {
          "type": "string"
        },
        "modifyDate": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "creator": {
          "type": "string"
        },
        "modifier": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "footer": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Parameter"
          }
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false
    },
    "PageLayout": {
      "type": "object",
      "description": "页面布局信息。PPT 中每个 Slide 使用该布局；瀑布流报告可作为页面级默认布局。",
      "properties": {
        "type": {
          "$ref": "#/$defs/LayoutType"
        },
        "autoLayout": {
          "type": "boolean"
        },
        "grid": {
          "type": "object",
          "properties": {
            "cols": {
              "type": "number"
            },
            "rowHeight": {
              "type": "number"
            },
            "gap": {
              "type": "number"
            }
          },
          "required": [
            "cols",
            "rowHeight"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "GridLayout": {
      "type": "object",
      "properties": {
        "type": {
          "const": "grid"
        },
        "gx": {
          "type": "number"
        },
        "gy": {
          "type": "number"
        },
        "gw": {
          "type": "number"
        },
        "gh": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "gx",
        "gy",
        "gw",
        "gh"
      ],
      "additionalProperties": false
    },
    "FlowLayout": {
      "type": "object",
      "properties": {
        "type": {
          "const": "flow"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "AbsoluteLayout": {
      "type": "object",
      "properties": {
        "type": {
          "const": "absolute"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        },
        "zIndex": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "x",
        "y",
        "w",
        "h"
      ],
      "additionalProperties": false
    },
    "ComponentLayout": {
      "oneOf": [
        {
          "$ref": "#/$defs/GridLayout"
        },
        {
          "$ref": "#/$defs/FlowLayout"
        },
        {
          "$ref": "#/$defs/AbsoluteLayout"
        }
      ]
    },
    "Cover": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "subTitle": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "layoutTemplate": {
          "$ref": "#/$defs/CoverLayoutType"
        },
        "image": {
          "type": "string"
        },
        "contents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CoverContent"
          }
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false
    },
    "SignaturePage": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "signers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Signer"
          }
        },
        "layoutTemplate": {
          "type": "string"
        }
      },
      "required": [
        "signers"
      ],
      "additionalProperties": false
    },
    "ReportSummary": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "overview": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "overview"
      ],
      "additionalProperties": false
    },
    "Catalog": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Catalog"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Section"
          }
        }
      },
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false
    },
    "Section": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BIEngineComponent"
          }
        },
        "summary": {
          "$ref": "#/$defs/ReportSummary"
        }
      },
      "required": [
        "id",
        "components"
      ],
      "additionalProperties": false
    },
    "GenerateMeta": {
      "type": "object",
      "description": "生成元数据。与 BI Engine GenerateMeta 对齐：记录生成状态、原始问题、附加证据、大纲快照和章节级参数。",
      "properties": {
        "status": {
          "$ref": "#/$defs/Status"
        },
        "question": {
          "type": "string"
        },
        "additionalInfos": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AdditionalInfo"
          }
        },
        "outline": {
          "$ref": "#/$defs/SectionOutline"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Parameter"
          }
        }
      },
      "required": [
        "status",
        "question"
      ],
      "additionalProperties": false
    },
    "AdditionalInfo": {
      "type": "object",
      "description": "生成附加信息。证据正文统一使用 value。",
      "properties": {
        "type": {
          "$ref": "#/$defs/AdditionalInfoType"
        },
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "appendix": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "additionalProperties": false
    },
    "ValueFormat": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "time"
            },
            "format": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "format"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "percentage"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "number"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "byte"
            },
            "decimal": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        }
      ]
    },
    "UIEvent": {
      "type": "object",
      "properties": {
        "trigger": {
          "type": "string",
          "enum": [
            "click",
            "dblclick",
            "hover"
          ]
        },
        "name": {
          "type": "string"
        },
        "dependency": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "trigger",
        "name",
        "dependency"
      ],
      "additionalProperties": false
    },
    "FieldUI": {
      "type": "object",
      "properties": {
        "displayPriority": {
          "type": "string",
          "enum": [
            "high",
            "normal",
            "never"
          ]
        },
        "valueFormat": {
          "$ref": "#/$defs/ValueFormat"
        },
        "event": {
          "$ref": "#/$defs/UIEvent"
        }
      },
      "additionalProperties": false
    },
    "EnumValue": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "title"
      ],
      "additionalProperties": false
    },
    "Column": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/FieldType"
        },
        "enumConfig": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EnumValue"
          }
        },
        "uiConfig": {
          "$ref": "#/$defs/FieldUI"
        },
        "colSpan": {
          "type": "number"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Column"
          }
        },
        "sortable": {
          "type": "boolean"
        },
        "filterable": {
          "type": "boolean"
        },
        "width": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            }
          ]
        }
      },
      "required": [
        "title",
        "key"
      ],
      "additionalProperties": false
    },
    "MergeColumnInfo": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "uniqueItems": true
        },
        "isMergeValue": {
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "columns"
      ],
      "additionalProperties": false
    },
    "MergeRowInfo": {
      "type": "object",
      "properties": {
        "startRowIndex": {
          "type": "integer",
          "minimum": 0
        },
        "rowSpan": {
          "type": "integer",
          "minimum": 2
        },
        "column": {
          "type": "string",
          "minLength": 1
        },
        "mergedText": {
          "type": "string"
        }
      },
      "required": [
        "startRowIndex",
        "rowSpan",
        "column"
      ],
      "additionalProperties": false,
      "description": "行合并信息。连续多行相同值合并后的渲染配置。"
    },
    "InteractionTrigger": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "click",
            "hover",
            "change",
            "select"
          ]
        },
        "field": {
          "type": "string"
        }
      },
      "required": [
        "action"
      ],
      "additionalProperties": false
    },
    "InteractionTarget": {
      "type": "object",
      "properties": {
        "componentId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "filter",
            "jump",
            "highlight"
          ]
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "componentId",
        "type"
      ],
      "additionalProperties": false
    },
    "Interaction": {
      "type": "object",
      "properties": {
        "trigger": {
          "$ref": "#/$defs/InteractionTrigger"
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InteractionTarget"
          }
        }
      },
      "required": [
        "trigger",
        "targets"
      ],
      "additionalProperties": false
    },
    "CommonDataProperty": {
      "type": "object",
      "properties": {
        "dataType": {
          "type": "string",
          "enum": [
            "static",
            "datasource",
            "api"
          ]
        },
        "sourceId": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "autoRefresh": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "number"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "dataType"
      ],
      "additionalProperties": false
    },
    "TextDataProperty": {
      "type": "object",
      "properties": {
        "dataType": {
          "type": "string",
          "enum": [
            "static",
            "datasource",
            "api"
          ]
        },
        "sourceId": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "autoRefresh": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
