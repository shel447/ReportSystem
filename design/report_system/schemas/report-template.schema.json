{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./report-template.schema.json",
  "title": "ReportTemplate",
  "description": "报告模板正式定义。模板定义是静态系统资产，不带运行态状态字段。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "name",
    "description",
    "schemaVersion",
    "parameters",
    "catalogs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_\\-]+$"
    },
    "category": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CatalogDefinition"
      }
    }
  },
  "$defs": {
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "inputType",
        "required",
        "multi",
        "interactionMode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "free_text",
            "date",
            "enum",
            "dynamic"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean",
          "default": false
        },
        "interactionMode": {
          "type": "string",
          "enum": [
            "form",
            "natural_language"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "runtimeContext": {
          "$ref": "#/$defs/ParameterRuntimeContext"
        },
        "source": {
          "type": "string",
          "description": "动态候选值来源地址。内容为 URL。"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "dynamic"
              }
            }
          },
          "then": {
            "required": [
              "source"
            ]
          }
        }
      ]
    },
    "ScopedParameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "OutlineDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "items"
      ],
      "properties": {
        "requirement": {
          "type": "string",
          "description": "章节诉求模板。可在文本中使用 {@itemId} 引用诉求项槽位。"
        },
        "renderedRequirement": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementItem"
          }
        }
      }
    },
    "RequirementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "search_target",
            "search_condition",
            "metric",
            "time_range",
            "filter",
            "threshold",
            "sort",
            "free_text",
            "parameter_ref"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "sourceParameterId": {
          "type": "string"
        },
        "widget": {
          "type": "string",
          "enum": [
            "input",
            "textarea",
            "select",
            "multi_select",
            "date",
            "date_range"
          ]
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "parameter_ref",
            "system_fill"
          ]
        }
      }
    },
    "ForeachDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterId",
        "as"
      ],
      "properties": {
        "parameterId": {
          "type": "string"
        },
        "as": {
          "type": "string"
        }
      }
    },
    "DatasetDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceType",
        "sourceRef"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "sql",
            "api",
            "llm",
            "compose"
          ]
        },
        "sourceRef": {
          "type": "string"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "PresentationBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "paragraph",
            "bullet",
            "kpi",
            "table",
            "chart",
            "markdown",
            "composite_table"
          ]
        },
        "title": {
          "type": "string"
        },
        "datasetId": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CompositeTablePart"
          },
          "minItems": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "composite_table"
              }
            }
          },
          "then": {
            "required": [
              "parts"
            ]
          }
        }
      ]
    },
    "CompositeTablePart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "sourceType"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "query",
            "summary"
          ]
        },
        "datasetId": {
          "type": "string"
        },
        "summarySpec": {
          "$ref": "#/$defs/SummaryTableSpec"
        },
        "tableLayout": {
          "$ref": "#/$defs/CompositeTablePartLayout"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "sourceType": {
                "const": "query"
              }
            }
          },
          "then": {
            "required": [
              "datasetId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "sourceType": {
                "const": "summary"
              }
            }
          },
          "then": {
            "required": [
              "summarySpec"
            ]
          }
        }
      ]
    },
    "CompositeTablePartLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "table"
          ]
        },
        "showHeader": {
          "type": "boolean"
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CompositeTableColumn"
          }
        }
      }
    },
    "CompositeTableColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "width": {
          "type": "string"
        },
        "align": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ]
        }
      }
    },
    "SummaryTableSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "partIds",
        "rows"
      ],
      "properties": {
        "partIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SummaryRowDef"
          },
          "minItems": 1
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "SummaryRowDef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "PresentationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "blocks"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "narrative",
            "table",
            "chart",
            "mixed"
          ]
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PresentationBlock"
          }
        }
      }
    },
    "SectionContentDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presentation"
      ],
      "properties": {
        "datasets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatasetDefinition"
          }
        },
        "presentation": {
          "$ref": "#/$defs/PresentationDefinition"
        }
      }
    },
    "SectionDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "outline",
        "content"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/$defs/ScopedParameters"
        },
        "foreach": {
          "$ref": "#/$defs/ForeachDefinition"
        },
        "outline": {
          "$ref": "#/$defs/OutlineDefinition"
        },
        "content": {
          "$ref": "#/$defs/SectionContentDefinition"
        }
      }
    },
    "CatalogDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "title": {
          "type": "string",
          "description": "目录标题模板。可直接在句子中使用 {$parameterId} 引用当前层级及父层级可见参数的 label 值。"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/$defs/ScopedParameters"
        },
        "foreach": {
          "$ref": "#/$defs/ForeachDefinition"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CatalogDefinition"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SectionDefinition"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "subCatalogs"
          ]
        }
      ]
    },
    "ParameterValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value",
        "query"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      }
    },
    "ParameterRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "dynamic_candidate",
            "parameter_ref",
            "system_fill"
          ]
        },
        "queryContext": {
          "type": "object",
          "additionalProperties": true
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        },
        "optionSource": {
          "type": "string"
        },
        "optionsFetchedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
