{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./report-template.schema.json",
  "title": "ReportTemplate",
  "description": "报告模板正式定义。模板定义是静态系统资产，不带运行态状态字段。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "name",
    "description",
    "schemaVersion",
    "parameters",
    "catalogs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_\\-]+$"
    },
    "category": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CatalogDefinition"
      }
    }
  },
  "$defs": {
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "inputType",
        "required",
        "multi",
        "interactionMode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "free_text",
            "date",
            "enum",
            "dynamic"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean",
          "default": false
        },
        "interactionMode": {
          "type": "string",
          "enum": [
            "form",
            "natural_language"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99,
          "default": 99,
          "description": "参数追问优先级。数字越小优先级越高；0 最高，99 最低。缺省按 99 处理。"
        },
        "placeholder": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "runtimeContext": {
          "$ref": "#/$defs/ParameterRuntimeContext"
        },
        "source": {
          "type": "string",
          "description": "动态候选值来源地址。内容为 URL。"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "dynamic"
              }
            }
          },
          "then": {
            "required": [
              "source"
            ]
          }
        }
      ]
    },
    "ScopedParameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "OutlineDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "items"
      ],
      "properties": {
        "requirement": {
          "type": "string",
          "description": "章节诉求模板。可在文本中使用 {@itemId} 引用诉求项槽位。"
        },
        "renderedRequirement": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementItem"
          }
        }
      }
    },
    "RequirementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "search_target",
            "search_condition",
            "metric",
            "time_range",
            "filter",
            "threshold",
            "sort",
            "free_text",
            "parameter_ref"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "sourceParameterId": {
          "type": "string"
        },
        "widget": {
          "type": "string",
          "enum": [
            "input",
            "textarea",
            "select",
            "multi_select",
            "date",
            "date_range"
          ]
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "parameter_ref",
            "system_fill"
          ]
        }
      }
    },
    "ForeachDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterId",
        "as"
      ],
      "properties": {
        "parameterId": {
          "type": "string"
        },
        "as": {
          "type": "string"
        }
      }
    },
    "DatasetDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceType",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "sql",
            "api",
            "llm",
            "compose"
          ]
        },
        "source": {
          "type": "string",
          "description": "数据源定义字符串。sourceType=sql 时为 SQL 模板；sourceType=api 时为 API URL；其它类型沿用统一字符串口径。"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "PresentationBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "table",
            "chart",
            "composite_table"
          ]
        },
        "title": {
          "type": "string"
        },
        "datasetId": {
          "type": "string"
        },
        "properties": {
          "$ref": "#/$defs/PresentationProperty"
        },
        "description": {
          "type": "string"
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CompositeTablePart"
          },
          "minItems": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "composite_table"
              }
            }
          },
          "then": {
            "required": [
              "parts"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": [
              "properties"
            ],
            "properties": {
              "properties": {
                "required": [
                  "template"
                ],
                "not": {
                  "required": [
                    "content"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "table"
              }
            }
          },
          "then": {
            "required": [
              "datasetId"
            ]
          }
        }
      ]
    },
    "PresentationProperty": {
      "type": "object",
      "description": "展示块附加展示属性。template 仅对 type=text 生效；content 仅对实例态 type=text 生效；preferredType 仅对 type=chart 生效；columns、showTitle、defaultDisplayRows、mergeColumns 仅对 type=table 的普通表格块生效。",
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "description": "文本展示块模板。仅对 type=text 生效，支持使用 {$parameterId} 引用参数，使用 {#datasetId.field} 引用同一 section 内 dataset 执行结果第一行的字段值；一个模板可引用多个 dataset。实例化后会渲染为实例态 properties.content。"
        },
        "content": {
          "type": "string",
          "description": "文本展示块实例化后的展示内容。仅对实例态 type=text 生效；模板态禁止保存 content。"
        },
        "preferredType": {
          "type": "string",
          "description": "图表首选展示类型，仅对 type=chart 生效。",
          "enum": [
            "line",
            "bar",
            "pie",
            "scatter",
            "radar",
            "gauge",
            "candlestick"
          ]
        },
        "columns": {
          "type": "array",
          "description": "普通表格列定义，仅对 type=table 生效。key 为 dataset 字段名，title 为展示名称。",
          "items": {
            "$ref": "#/$defs/TableColumn"
          }
        },
        "showTitle": {
          "type": "boolean",
          "description": "普通表格是否显示表格标题，仅影响展示，不改变 title 字段本身。"
        },
        "defaultDisplayRows": {
          "type": "integer",
          "minimum": 1,
          "description": "普通表格默认展示数据条数，仅作为展示提示，不截断 dataset 结果。"
        },
        "mergeColumns": {
          "type": "array",
          "description": "普通表格的合并列定义，仅对 type=table 生效。",
          "items": {
            "$ref": "#/$defs/MergeColumnInfo"
          }
        }
      }
    },
    "CompositeTablePart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "sourceType"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "query",
            "summary"
          ]
        },
        "datasetId": {
          "type": "string"
        },
        "summarySpec": {
          "$ref": "#/$defs/SummaryTableSpec"
        },
        "tableLayout": {
          "$ref": "#/$defs/CompositeTablePartLayout"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "sourceType": {
                "const": "query"
              }
            }
          },
          "then": {
            "required": [
              "datasetId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "sourceType": {
                "const": "summary"
              }
            }
          },
          "then": {
            "required": [
              "summarySpec"
            ]
          }
        }
      ]
    },
    "CompositeTablePartLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "table"
          ]
        },
        "showHeader": {
          "type": "boolean"
        },
        "showTitle": {
          "type": "boolean",
          "description": "是否显示该 part 的表格标题，仅影响展示，不改变 title 字段本身。"
        },
        "defaultDisplayRows": {
          "type": "integer",
          "minimum": 1,
          "description": "该 part 默认展示数据条数，仅作为展示提示，不截断 dataset 结果。"
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TableColumn"
          }
        },
        "mergeColumns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MergeColumnInfo"
          }
        }
      }
    },
    "TableColumn": {
      "type": "object",
      "description": "表格列定义。key/title 为正式字段；width/align 为兼容保留字段，v1 暂不承诺渲染支持。",
      "additionalProperties": false,
      "required": [
        "key",
        "title"
      ],
      "properties": {
        "key": {
          "type": "string",
          "description": "dataset 执行结果中的字段 key。"
        },
        "title": {
          "type": "string",
          "description": "表格展示列名。"
        },
        "width": {
          "type": "string",
          "description": "兼容保留字段，v1 暂不承诺渲染支持。"
        },
        "align": {
          "type": "string",
          "description": "兼容保留字段，v1 暂不承诺渲染支持。",
          "enum": [
            "left",
            "center",
            "right"
          ]
        }
      }
    },
    "CompositeTableColumn": {
      "description": "兼容旧名称，等价于 TableColumn。",
      "$ref": "#/$defs/TableColumn"
    },
    "MergeColumnInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "columns"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "uniqueItems": true
        }
      }
    },
    "SummaryTableSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "partIds",
        "rows"
      ],
      "properties": {
        "partIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SummaryRowDef"
          },
          "minItems": 1
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "SummaryRowDef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "PresentationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "blocks"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "text",
            "table",
            "chart",
            "mixed"
          ]
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PresentationBlock"
          }
        }
      }
    },
    "SectionContentDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presentation"
      ],
      "properties": {
        "datasets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatasetDefinition"
          }
        },
        "presentation": {
          "$ref": "#/$defs/PresentationDefinition"
        }
      }
    },
    "SectionDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "outline",
        "content"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/$defs/ScopedParameters"
        },
        "foreach": {
          "$ref": "#/$defs/ForeachDefinition"
        },
        "outline": {
          "$ref": "#/$defs/OutlineDefinition"
        },
        "content": {
          "$ref": "#/$defs/SectionContentDefinition"
        }
      }
    },
    "CatalogDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$"
        },
        "title": {
          "type": "string",
          "description": "目录标题模板。可直接在句子中使用 {$parameterId} 引用当前层级及父层级可见参数的 label 值。"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/$defs/ScopedParameters"
        },
        "foreach": {
          "$ref": "#/$defs/ForeachDefinition"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CatalogDefinition"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SectionDefinition"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "subCatalogs"
          ]
        }
      ]
    },
    "ParameterValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value",
        "query"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      }
    },
    "ParameterRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "dynamic_candidate",
            "parameter_ref",
            "system_fill"
          ]
        },
        "queryContext": {
          "type": "object",
          "additionalProperties": true
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        },
        "optionSource": {
          "type": "string"
        },
        "optionsFetchedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
