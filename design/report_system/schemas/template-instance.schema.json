{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./template-instance.schema.json",
  "title": "TemplateInstance",
  "description": "模板实例正式定义。模板实例是对话运行态对象，structureType=flow 时主体保持 catalogs -> (subCatalogs)* -> sections，structureType=paged 时主体使用 chapters -> slides -> sections；参数与诉求统一复用渐进式核心模型。section.content 保留实例化后的内容视图，复合表在 block/part 级维护运行态。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "templateId",
    "template",
    "conversationId",
    "status",
    "captureStage",
    "revision",
    "parameters",
    "parameterConfirmation",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "templateId": {
      "type": "string"
    },
    "conversationId": {
      "type": "string"
    },
    "chatId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "collecting_parameters",
        "ready_for_confirmation",
        "confirmed",
        "generating",
        "completed",
        "failed"
      ]
    },
    "captureStage": {
      "type": "string",
      "enum": [
        "fill_params",
        "confirm_params",
        "generate_report",
        "report_ready"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "structureType": {
      "type": "string",
      "enum": [
        "flow",
        "paged"
      ],
      "default": "flow",
      "description": "模板实例结构类型。缺省为 flow；flow 使用 catalogs，paged 使用 chapters。"
    },
    "parameters": {
      "type": "array",
      "description": "模板实例根部参数。与模板、ask、reply 复用同一套参数模型；实例态通过 options/values/runtimeContext 表达最新状态。",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "parameterConfirmation": {
      "$ref": "#/$defs/ParameterConfirmation"
    },
    "catalogs": {
      "description": "瀑布流模板实例结构入口，仅在 structureType=flow 或缺省时生效。",
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateInstanceCatalog"
      }
    },
    "chapters": {
      "description": "分页模板实例结构入口，仅在 structureType=paged 时生效。",
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateInstanceChapter"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/WarningItem"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "template": {
      "$ref": "./report-template.schema.json",
      "description": "模板实例冻结时使用的完整模板快照。二次编辑与重新生成必须以该模板为准，不能回读线上最新模板。"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "structureType"
        ],
        "properties": {
          "structureType": {
            "const": "paged"
          }
        }
      },
      "then": {
        "required": [
          "chapters"
        ],
        "not": {
          "required": [
            "catalogs"
          ]
        }
      },
      "else": {
        "required": [
          "catalogs"
        ],
        "not": {
          "required": [
            "chapters"
          ]
        }
      }
    }
  ],
  "$defs": {
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "ParameterConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missingParameterIds",
        "confirmed"
      ],
      "properties": {
        "missingParameterIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "inputType",
        "required",
        "multi",
        "interactionMode"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "free_text",
            "date",
            "enum",
            "dynamic"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "interactionMode": {
          "type": "string",
          "enum": [
            "form",
            "natural_language"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99,
          "default": 99,
          "description": "参数追问优先级。数字越小优先级越高；0 最高，99 最低。缺省按 99 处理。"
        },
        "placeholder": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "runtimeContext": {
          "$ref": "#/$defs/ParameterRuntimeContext"
        },
        "source": {
          "type": "string",
          "description": "动态候选值来源地址。内容为 URL。"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "dynamic"
              }
            }
          },
          "then": {
            "required": [
              "source"
            ]
          }
        }
      ]
    },
    "RequirementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "sourceParameterId": {
          "type": "string"
        },
        "widget": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "parameter_ref",
            "system_fill"
          ]
        }
      }
    },
    "Outline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "items"
      ],
      "properties": {
        "requirement": {
          "type": "string"
        },
        "renderedRequirement": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementItem"
          }
        }
      }
    },
    "ForeachContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterId",
        "itemValues"
      ],
      "properties": {
        "parameterId": {
          "type": "string"
        },
        "itemValues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        }
      }
    },
    "DynamicContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "foreach",
            "foreachCase",
            "custom"
          ]
        },
        "parameterId": {
          "type": "string"
        },
        "itemValue": {
          "$ref": "#/$defs/ParameterValue"
        },
        "caseId": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "nodeType": {
          "type": "string",
          "enum": [
            "catalog",
            "section"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "custom"
              }
            }
          },
          "then": {
            "required": [
              "url",
              "nodeType"
            ]
          },
          "else": {
            "required": [
              "parameterId"
            ]
          }
        }
      ]
    },
    "ExecutionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "bindingType",
        "sourceType",
        "targetRef"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "bindingType": {
          "type": "string",
          "enum": [
            "dataset_parameter",
            "requirement_mapping",
            "render_hint"
          ]
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "sql",
            "api",
            "llm",
            "system"
          ]
        },
        "targetRef": {
          "type": "string"
        },
        "multiValueQueryMode": {
          "type": "string",
          "description": "多值查询组合策略。默认推荐使用 in。",
          "enum": [
            "single",
            "in",
            "or",
            "and",
            "custom"
          ]
        },
        "queryTemplate": {
          "type": "string",
          "description": "仅在 multiValueQueryMode=custom 时使用的查询模板。"
        },
        "resolvedQuery": {
          "type": "string",
          "description": "对执行层可直接使用的最终查询表达式。多值场景由 values 和 multiValueQueryMode 生成。"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "DatasetDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceType",
        "sourceRef"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sourceType": {
          "type": "string",
          "enum": ["sql", "api", "llm", "compose"]
        },
        "sourceRef": { "type": "string" },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" }
      }
    },
    "TemplateInstanceSectionContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presentation"],
      "properties": {
        "datasets": {
          "type": "array",
          "items": { "$ref": "#/$defs/DatasetDefinition" }
        },
        "presentation": { "$ref": "#/$defs/TemplateInstancePresentationDefinition" }
      }
    },
    "TemplateInstancePresentationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "blocks"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["text", "table", "chart", "mixed"]
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/TemplateInstancePresentationBlock" }
        }
      }
    },
    "TemplateInstancePresentationBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["text", "table", "chart", "composite_table"]
        },
        "title": { "type": "string" },
        "datasetId": { "type": "string" },
        "properties": {
          "$ref": "./report-template.schema.json#/$defs/PresentationProperty",
          "description": "实例态展示属性，复用模板 PresentationProperty；text 使用 template/content，chart 使用 preferredType，普通 table 使用 columns/showTitle/defaultDisplayRows/mergeColumns/mergeRows。"
        },
        "description": { "type": "string" },
        "parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/TemplateInstanceCompositeTablePart" },
          "minItems": 1
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "composite_table" } } },
          "then": { "required": ["parts"] }
        },
        {
          "if": { "properties": { "type": { "const": "text" } } },
          "then": {
            "required": ["properties"],
            "properties": {
              "properties": {
                "required": ["template", "content"]
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "table" } } },
          "then": { "required": ["datasetId"] }
        }
      ]
    },
    "TemplateInstanceCompositeTablePart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "sourceType", "runtimeContext"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "sourceType": {
          "type": "string",
          "enum": ["query", "summary"]
        },
        "datasetId": { "type": "string" },
        "summarySpec": { "$ref": "./report-template.schema.json#/$defs/SummaryTableSpec" },
        "tableLayout": {
          "$ref": "./report-template.schema.json#/$defs/CompositeTablePartLayout",
          "description": "实例态复合表 part 布局，复用模板 CompositeTablePartLayout，包含 columns/showTitle/defaultDisplayRows/mergeColumns/mergeRows 等展示属性。"
        },
        "runtimeContext": { "$ref": "#/$defs/PartRuntimeContext" }
      },
      "allOf": [
        {
          "if": { "properties": { "sourceType": { "const": "query" } } },
          "then": { "required": ["datasetId"] }
        },
        {
          "if": { "properties": { "sourceType": { "const": "summary" } } },
          "then": { "required": ["summarySpec"] }
        }
      ]
    },
    "PartRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "running", "finished", "failed"]
        },
        "resolvedDatasetId": { "type": "string" },
        "resolvedQuery": { "type": "string" },
        "resolvedPartIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prompt": { "type": "string" },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/WarningItem" }
        }
      }
    },
    "SectionSkeletonStatus": {
      "type": "string",
      "enum": [
        "reusable",
        "conditionally_reusable",
        "broken"
      ]
    },
    "TemplateInstanceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "outline",
        "content",
        "runtimeContext",
        "skeletonStatus",
        "userEdited"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "dynamicContext": {
          "$ref": "#/$defs/DynamicContext"
        },
        "outline": {
          "$ref": "#/$defs/Outline"
        },
        "content": {
          "$ref": "#/$defs/TemplateInstanceSectionContent"
        },
        "skeletonStatus": {
          "$ref": "#/$defs/SectionSkeletonStatus"
        },
        "userEdited": {
          "type": "boolean"
        },
        "runtimeContext": {
          "$ref": "#/$defs/SectionRuntimeContext"
        }
      }
    },
    "TemplateInstanceCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "renderedTitle"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "description": "目录标题模板。可直接在句子中使用 {$parameterId} 引用当前层级及父层级可见参数的 label 值。"
        },
        "renderedTitle": {
          "type": "string",
          "description": "实例态最终展示给用户和报告目录的目录标题。"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "dynamicContext": {
          "$ref": "#/$defs/DynamicContext"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceCatalog"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceSection"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "subCatalogs"
          ]
        },
        {
          "required": [
            "dynamicContext"
          ]
        }
      ]
    },
    "TemplateInstanceSlide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sections"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "dynamicContext": {
          "$ref": "#/$defs/DynamicContext"
        },
        "layout": {
          "$ref": "./report-template.schema.json#/$defs/SlideLayout",
          "description": "实例态分页页面布局提示，复用模板 SlideLayout。"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceSection"
          }
        }
      }
    },
    "TemplateInstanceChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slides"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "implicit": {
          "type": "boolean",
          "description": "是否为系统隐式生成的默认章节。"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "dynamicContext": {
          "$ref": "#/$defs/DynamicContext"
        },
        "slides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceSlide"
          }
        }
      }
    },
    "WarningItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        }
      }
    },
    "ParameterValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value",
        "query"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      }
    },
    "ParameterRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "dynamic_candidate",
            "parameter_ref",
            "system_fill"
          ]
        },
        "queryContext": {
          "type": "object",
          "additionalProperties": true
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        },
        "optionSource": {
          "type": "string"
        },
        "optionsFetchedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "SectionRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindings"
      ],
      "properties": {
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ExecutionBinding"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
