{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./template-instance.schema.json",
  "title": "TemplateInstance",
  "description": "模板实例正式定义。模板实例是对话运行态对象，主体保持 catalogs -> (subCatalogs)* -> sections 层级；参数与诉求统一复用渐进式核心模型。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "templateId",
    "templateSnapshot",
    "conversationId",
    "status",
    "captureStage",
    "revision",
    "parameters",
    "parameterConfirmation",
    "catalogs",
    "deltaViews",
    "templateSkeletonStatus",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "templateId": {
      "type": "string"
    },
    "templateSnapshot": {
      "$ref": "./report-template.schema.json",
      "description": "模板实例冻结时使用的完整模板快照。二次编辑与重新生成必须以该快照为准，不能回读线上最新模板。"
    },
    "conversationId": {
      "type": "string"
    },
    "chatId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "collecting_parameters",
        "ready_for_confirmation",
        "confirmed",
        "generating",
        "completed",
        "failed"
      ]
    },
    "captureStage": {
      "type": "string",
      "enum": [
        "fill_params",
        "confirm_params",
        "generate_report",
        "report_ready"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "parameters": {
      "type": "array",
      "description": "模板实例根部参数。与模板、ask、reply 复用同一套参数模型；实例态可带 candidates/values/runtime。",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "parameterConfirmation": {
      "$ref": "#/$defs/ParameterConfirmation"
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateInstanceCatalog"
      }
    },
    "deltaViews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateInstanceDelta"
      }
    },
    "templateSkeletonStatus": {
      "$ref": "#/$defs/TemplateSkeletonStatus"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/WarningItem"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "TrioValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display",
        "value",
        "query"
      ],
      "properties": {
        "display": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      }
    },
    "OpenSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "ParameterRuntime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "dynamic_candidate",
            "parameter_ref",
            "system_fill"
          ]
        },
        "candidateSource": {
          "type": "string"
        },
        "candidateFetchedAt": {
          "type": "string",
          "format": "date-time"
        },
        "queryContext": {
          "type": "object",
          "additionalProperties": true
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ParameterConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missingParameterIds",
        "confirmed"
      ],
      "properties": {
        "missingParameterIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "inputType",
        "required",
        "multi",
        "interactionMode",
        "valueMode"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "free_text",
            "date",
            "enum",
            "dynamic"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "interactionMode": {
          "type": "string",
          "enum": [
            "form",
            "natural_language"
          ]
        },
        "valueMode": {
          "type": "string",
          "enum": [
            "display",
            "value",
            "query"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "openSource": {
          "$ref": "#/$defs/OpenSource"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "runtime": {
          "$ref": "#/$defs/ParameterRuntime"
        }
      }
    },
    "RequirementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "sourceParameterId": {
          "type": "string"
        },
        "widget": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        },
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "parameter_ref",
            "system_fill"
          ]
        }
      }
    },
    "Outline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "items"
      ],
      "properties": {
        "requirement": {
          "type": "string"
        },
        "renderedRequirement": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementItem"
          }
        }
      }
    },
    "ForeachContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterId",
        "itemValues"
      ],
      "properties": {
        "parameterId": {
          "type": "string"
        },
        "itemValues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrioValue"
          }
        }
      }
    },
    "ExecutionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "bindingType",
        "sourceType",
        "targetRef"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "bindingType": {
          "type": "string",
          "enum": [
            "dataset_parameter",
            "requirement_mapping",
            "render_hint"
          ]
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "sql",
            "api",
            "llm",
            "system"
          ]
        },
        "targetRef": {
          "type": "string"
        },
        "multiValueQueryMode": {
          "type": "string",
          "description": "多值查询组合策略。默认推荐使用 in。",
          "enum": [
            "single",
            "in",
            "or",
            "and",
            "custom"
          ]
        },
        "queryTemplate": {
          "type": "string",
          "description": "仅在 multiValueQueryMode=custom 时使用的查询模板。"
        },
        "resolvedQuery": {
          "type": "string",
          "description": "对执行层可直接使用的最终查询表达式。多值场景由 values 和 multiValueQueryMode 生成。"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "SectionSkeletonStatus": {
      "type": "string",
      "enum": [
        "reusable",
        "conditionally_reusable",
        "broken"
      ]
    },
    "TemplateInstanceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "outline",
        "executionBindings",
        "skeletonStatus",
        "userEdited"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "titleTemplate": {
          "type": "string"
        },
        "foreachContext": {
          "$ref": "#/$defs/ForeachContext"
        },
        "outline": {
          "$ref": "#/$defs/Outline"
        },
        "executionBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ExecutionBinding"
          }
        },
        "skeletonStatus": {
          "$ref": "#/$defs/SectionSkeletonStatus"
        },
        "userEdited": {
          "type": "boolean"
        }
      }
    },
    "TemplateInstanceCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "nameTemplate": {
          "type": "string"
        },
        "foreachContext": {
          "$ref": "#/$defs/ForeachContext"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceCatalog"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceSection"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "subCatalogs"
          ]
        }
      ]
    },
    "TemplateInstanceDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetType",
        "targetId",
        "changeKind"
      ],
      "properties": {
        "targetType": {
          "type": "string",
          "enum": [
            "parameter",
            "catalog",
            "section",
            "requirement_item"
          ]
        },
        "targetId": {
          "type": "string"
        },
        "catalogPath": {
          "type": "array",
          "description": "多层目录下的辅助定位路径，按祖先到当前目录的 id 顺序给出。它不替代 targetId，只用于审计、回放和前后端稳态定位。",
          "items": {
            "type": "string"
          }
        },
        "sectionPath": {
          "type": "array",
          "description": "多层目录下章节辅助定位路径，通常为 catalogPath 后追加 section id。仅在需要稳态定位具体章节时返回。",
          "items": {
            "type": "string"
          }
        },
        "changeKind": {
          "type": "string",
          "enum": [
            "slot_value_update",
            "text_edit",
            "structure_edit",
            "binding_break",
            "binding_restore",
            "reorder"
          ]
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "TemplateSkeletonStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "internal",
        "ui"
      ],
      "properties": {
        "internal": {
          "type": "string",
          "enum": [
            "reusable",
            "conditionally_reusable",
            "broken"
          ]
        },
        "ui": {
          "type": "string",
          "enum": [
            "not_broken",
            "broken"
          ]
        }
      }
    },
    "WarningItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        }
      }
    }
  }
}
