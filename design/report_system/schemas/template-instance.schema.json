{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./template-instance.schema.json",
  "title": "TemplateInstance",
  "description": "模板实例正式定义。模板实例是对话运行态对象，主体保持 catalogs -> (subCatalogs)* -> sections 层级；参数与诉求统一复用渐进式核心模型。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "templateId",
    "template",
    "conversationId",
    "status",
    "captureStage",
    "revision",
    "parameters",
    "parameterConfirmation",
    "catalogs",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "templateId": {
      "type": "string"
    },
    "conversationId": {
      "type": "string"
    },
    "chatId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "collecting_parameters",
        "ready_for_confirmation",
        "confirmed",
        "generating",
        "completed",
        "failed"
      ]
    },
    "captureStage": {
      "type": "string",
      "enum": [
        "fill_params",
        "confirm_params",
        "generate_report",
        "report_ready"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "parameters": {
      "type": "array",
      "description": "模板实例根部参数。与模板、ask、reply 复用同一套参数模型；实例态通过 options/values/runtimeContext 表达最新状态。",
      "items": {
        "$ref": "#/$defs/Parameter"
      }
    },
    "parameterConfirmation": {
      "$ref": "#/$defs/ParameterConfirmation"
    },
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateInstanceCatalog"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/WarningItem"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "template": {
      "$ref": "./report-template.schema.json",
      "description": "模板实例冻结时使用的完整模板快照。二次编辑与重新生成必须以该模板为准，不能回读线上最新模板。"
    }
  },
  "$defs": {
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "ParameterConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missingParameterIds",
        "confirmed"
      ],
      "properties": {
        "missingParameterIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "inputType",
        "required",
        "multi",
        "interactionMode"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "free_text",
            "date",
            "enum",
            "dynamic"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "interactionMode": {
          "type": "string",
          "enum": [
            "form",
            "natural_language"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "runtimeContext": {
          "$ref": "#/$defs/ParameterRuntimeContext"
        },
        "source": {
          "type": "string",
          "description": "动态候选值来源地址。内容为 URL。"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inputType": {
                "const": "dynamic"
              }
            }
          },
          "then": {
            "required": [
              "source"
            ]
          }
        }
      ]
    },
    "RequirementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "sourceParameterId": {
          "type": "string"
        },
        "widget": {
          "type": "string"
        },
        "defaultValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        },
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "parameter_ref",
            "system_fill"
          ]
        }
      }
    },
    "Outline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "items"
      ],
      "properties": {
        "requirement": {
          "type": "string"
        },
        "renderedRequirement": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementItem"
          }
        }
      }
    },
    "ForeachContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterId",
        "itemValues"
      ],
      "properties": {
        "parameterId": {
          "type": "string"
        },
        "itemValues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterValue"
          }
        }
      }
    },
    "ExecutionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "bindingType",
        "sourceType",
        "targetRef"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "bindingType": {
          "type": "string",
          "enum": [
            "dataset_parameter",
            "requirement_mapping",
            "render_hint"
          ]
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "sql",
            "api",
            "llm",
            "system"
          ]
        },
        "targetRef": {
          "type": "string"
        },
        "multiValueQueryMode": {
          "type": "string",
          "description": "多值查询组合策略。默认推荐使用 in。",
          "enum": [
            "single",
            "in",
            "or",
            "and",
            "custom"
          ]
        },
        "queryTemplate": {
          "type": "string",
          "description": "仅在 multiValueQueryMode=custom 时使用的查询模板。"
        },
        "resolvedQuery": {
          "type": "string",
          "description": "对执行层可直接使用的最终查询表达式。多值场景由 values 和 multiValueQueryMode 生成。"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "SectionSkeletonStatus": {
      "type": "string",
      "enum": [
        "reusable",
        "conditionally_reusable",
        "broken"
      ]
    },
    "TemplateInstanceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "outline",
        "runtimeContext",
        "skeletonStatus",
        "userEdited"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "foreachContext": {
          "$ref": "#/$defs/ForeachContext"
        },
        "outline": {
          "$ref": "#/$defs/Outline"
        },
        "skeletonStatus": {
          "$ref": "#/$defs/SectionSkeletonStatus"
        },
        "userEdited": {
          "type": "boolean"
        },
        "runtimeContext": {
          "$ref": "#/$defs/SectionRuntimeContext"
        }
      }
    },
    "TemplateInstanceCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "renderedTitle"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "description": "目录标题模板。可直接在句子中使用 {$parameterId} 引用当前层级及父层级可见参数的 display 值。"
        },
        "renderedTitle": {
          "type": "string",
          "description": "实例态最终展示给用户和报告目录的目录标题。"
        },
        "description": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        },
        "foreachContext": {
          "$ref": "#/$defs/ForeachContext"
        },
        "subCatalogs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceCatalog"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TemplateInstanceSection"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "subCatalogs"
          ]
        }
      ]
    },
    "WarningItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        }
      }
    },
    "ParameterValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display",
        "value",
        "query"
      ],
      "properties": {
        "display": {
          "$ref": "#/$defs/Scalar"
        },
        "value": {
          "$ref": "#/$defs/Scalar"
        },
        "query": {
          "$ref": "#/$defs/Scalar"
        }
      }
    },
    "ParameterRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueSource": {
          "type": "string",
          "enum": [
            "user_input",
            "default",
            "dynamic_candidate",
            "parameter_ref",
            "system_fill"
          ]
        },
        "queryContext": {
          "type": "object",
          "additionalProperties": true
        },
        "confirmed": {
          "type": "boolean"
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time"
        },
        "optionSource": {
          "type": "string"
        },
        "optionsFetchedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "SectionRuntimeContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindings"
      ],
      "properties": {
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ExecutionBinding"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
