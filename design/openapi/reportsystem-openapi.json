      "ChatStreamEvent": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "status",
              "step_delta",
              "ask",
              "answer",
              "error",
              "done"
            ]
          },
          "sequence": {
            "type": "integer"
          },
          "timestamp": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "delta": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportDelta"
            }
          },
          "step": {
            "$ref": "#/components/schemas/Step"
          },
          "ask": {
            "$ref": "#/components/schemas/Ask"
          },
          "answer": {
            "$ref": "#/components/schemas/AnswerEnvelope"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "eventType": {
                  "const": "status"
                }
              }
            },
            "then": {
              "required": [
                "status"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "eventType": {
                  "const": "step_delta"
                }
              }
            },
            "then": {
              "required": [
                "step"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "eventType": {
                  "const": "ask"
                }
              }
            },
            "then": {
              "required": [
                "ask"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "eventType": {
                  "const": "answer"
                }
              }
            },
            "then": {
              "required": [
                "answer"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "eventType": {
                  "const": "error"
                }
              }
            },
            "then": {
              "required": [
                "error"
              ]
            }
          }
        ],
        "required": [
          "conversationId",
          "chatId",
          "eventType",
          "sequence",
          "timestamp"
        ]
      },
      "ReportDelta": {
        "type": "object",
        "properties": {
          "action": {
