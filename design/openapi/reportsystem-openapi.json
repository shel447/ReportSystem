{
  "openapi": "3.1.0",
  "info": {
    "title": "ReportSystem Public API",
    "version": "2026-04-18",
    "description": "报告主系统公开接口。模板、模板实例和报告 DSL 的正式模型定义\n统一收敛到 design/report_system/schemas 下的 JSON Schema 文件。\n"
  },
  "servers": [
    {
      "url": "/rest/chatbi/v1"
    }
  ],
  "security": [
    {
      "XUserIdHeader": []
    }
  ],
  "tags": [
    {
      "name": "templates"
    },
    {
      "name": "chat"
    },
    {
      "name": "reports"
    },
    {
      "name": "parameter-options"
    }
  ],
  "paths": {
    "/templates": {
      "get": {
        "tags": [
          "templates"
        ],
        "summary": "List template summaries",
        "operationId": "listTemplates",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TemplateSummary"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "items",
                    "total"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "templates"
        ],
        "summary": "Create template",
        "operationId": "createTemplate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportTemplate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTemplate"
                }
              }
            }
          },
          "409": {
            "description": "Template id already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/templates/{id}": {
      "get": {
        "tags": [
          "templates"
        ],
        "summary": "Get template detail",
        "operationId": "getTemplate",
        "parameters": [
          {
            "$ref": "#/components/parameters/TemplateId"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTemplate"
                }
              }
            }
          },
          "400": {
            "description": "Path id and body id mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "templates"
        ],
        "summary": "Update template",
        "operationId": "updateTemplate",
        "parameters": [
          {
            "$ref": "#/components/parameters/TemplateId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportTemplate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTemplate"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "templates"
        ],
        "summary": "Delete template",
        "operationId": "deleteTemplate",
        "parameters": [
          {
            "$ref": "#/components/parameters/TemplateId"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    },
    "/templates/import/preview": {
      "post": {
        "tags": [
          "templates"
        ],
        "summary": "Preview template import",
        "operationId": "previewTemplateImport",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TemplateImportPreviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateImportPreviewResponse"
                }
              }
            }
          }
        }
      }
    },
    "/templates/{id}/export": {
      "get": {
        "tags": [
          "templates"
        ],
        "summary": "Export template",
        "operationId": "exportTemplate",
        "parameters": [
          {
            "$ref": "#/components/parameters/TemplateId"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportTemplate"
                }
              }
            }
          }
        }
      }
    },
    "/chat": {
      "get": {
        "tags": [
          "chat"
        ],
        "summary": "List conversations",
        "operationId": "listConversations",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ConversationSummary"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "items",
                    "total"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Send chat turn",
        "operationId": "sendChatTurn",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat snapshot response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "206": {
            "description": "Streaming chat events",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/ChatStreamEvent"
                }
              }
            }
          }
        }
      }
    },
    "/chat/forks": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Fork conversation or reopen from template instance",
        "operationId": "forkConversation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetail"
                }
              }
            }
          }
        }
      }
    },
    "/chat/{conversationId}": {
      "get": {
        "tags": [
          "chat"
        ],
        "summary": "Get conversation detail",
        "operationId": "getConversation",
        "parameters": [
          {
            "$ref": "#/components/parameters/ConversationId"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetail"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "chat"
        ],
        "summary": "Delete conversation",
        "operationId": "deleteConversation",
        "parameters": [
          {
            "$ref": "#/components/parameters/ConversationId"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    },
    "/reports/{reportId}": {
      "get": {
        "tags": [
          "reports"
        ],
        "summary": "Get report resource",
        "operationId": "getReport",
        "parameters": [
          {
            "$ref": "#/components/parameters/ReportId"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportInstanceResource"
                }
              }
            }
          }
        }
      }
    },
    "/reports/{reportId}/document-generations": {
      "post": {
        "tags": [
          "reports"
        ],
        "summary": "Generate report documents",
        "operationId": "generateReportDocuments",
        "parameters": [
          {
            "$ref": "#/components/parameters/ReportId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentGenerationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentGenerationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reports/{reportId}/documents/{documentId}/download": {
      "get": {
        "tags": [
          "reports"
        ],
        "summary": "Download generated document",
        "operationId": "downloadDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/ReportId"
          },
          {
            "$ref": "#/components/parameters/DocumentId"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to file storage URL"
          }
        }
      }
    },
    "/parameter-options/resolve": {
      "post": {
        "tags": [
          "parameter-options"
        ],
        "summary": "Resolve dynamic parameter options",
        "operationId": "resolveParameterOptions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParameterOptionsResolveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParameterOptionsResolveResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "XUserIdHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-User-Id"
      }
    },
    "parameters": {
      "TemplateId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ConversationId": {
        "name": "conversationId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ReportId": {
        "name": "reportId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "DocumentId": {
        "name": "documentId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "ReportTemplate": {
        "$ref": "../report_system/schemas/report-template.schema.json"
      },
      "TemplateInstance": {
        "$ref": "../report_system/schemas/template-instance.schema.json"
      },
      "ReportDsl": {
        "$ref": "../report_system/schemas/report-dsl.schema.json"
      },
      "ParameterValue": {
        "$ref": "../report_system/schemas/report-template.schema.json#/$defs/ParameterValue"
      },
      "TemplateSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "schemaVersion": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "category",
          "name",
          "description",
          "schemaVersion"
        ]
      },
      "TemplateImportPreviewRequest": {
        "type": "object",
        "properties": {
          "content": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          }
        },
        "required": [
          "content"
        ]
      },
      "TemplateImportPreviewResponse": {
        "type": "object",
        "properties": {
          "normalizedTemplate": {
            "$ref": "#/components/schemas/ReportTemplate"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WarningItem"
            }
          }
        },
        "required": [
          "normalizedTemplate",
          "warnings"
        ]
      },
      "WarningItem": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "典型模板相关错误码包括：\nTEMPLATE_SCHEMA_INVALID、TEMPLATE_DUPLICATE_PARAMETER_ID、\nTEMPLATE_DUPLICATE_SECTION_ID、TEMPLATE_EMPTY_CATALOG、\nTEMPLATE_ID_CONFLICT、TEMPLATE_PATH_ID_MISMATCH。\n"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WarningItem"
            }
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "ConversationSummary": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "conversationId",
          "title",
          "status",
          "updatedAt"
        ]
      },
      "ConversationDetail": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "chats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            }
          }
        },
        "required": [
          "conversationId",
          "title",
          "status",
          "chats"
        ]
      },
      "ChatMessage": {
        "type": "object",
        "properties": {
          "chatId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant",
              "system"
            ]
          },
          "content": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "chatId",
          "conversationId",
          "role",
          "content"
        ]
      },
      "ChatRequest": {
        "type": "object",
        "description": "统一对话请求包络。\n`question` 与 `reply` 至少应出现一个。\n`attachments` 仅在 `extract_report_template` 且需要上传原始材料时必填。\n`histories` 仅在基于历史对话生成报告时必填。\n",
        "anyOf": [
          {
            "required": [
              "question"
            ]
          },
          {
            "required": [
              "reply"
            ]
          }
        ],
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "question": {
            "type": "string",
            "nullable": true
          },
          "instruction": {
            "type": "string",
            "enum": [
              "generate_report",
              "extract_report_template"
            ]
          },
          "reply": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Reply"
              }
            ]
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "name",
                "content"
              ]
            }
          },
          "histories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            }
          },
          "requestId": {
            "type": "string"
          },
          "apiVersion": {
            "type": "string"
          }
        },
        "required": [
          "conversationId",
          "chatId",
          "instruction",
          "requestId",
          "apiVersion"
        ]
      },
      "Reply": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "fill_params",
              "confirm_params"
            ]
          },
          "parameters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Parameter"
            }
          },
          "reportContext": {
            "type": "object",
            "properties": {
              "templateInstance": {
                "$ref": "#/components/schemas/TemplateInstance"
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "fill_params"
                }
              }
            },
            "then": {
              "required": [
                "parameters"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "confirm_params"
                }
              }
            },
            "then": {
              "required": [
                "parameters",
                "reportContext"
              ]
            }
          }
        ],
        "required": [
          "type"
        ]
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "waiting_user",
              "running",
              "finished",
              "failed"
            ]
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Step"
            }
          },
          "ask": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Ask"
              }
            ]
          },
          "answer": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/AnswerEnvelope"
              }
            ]
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "code",
                "message"
              ]
            }
          },
          "requestId": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          },
          "apiVersion": {
            "type": "string"
          }
        },
        "required": [
          "conversationId",
          "chatId",
          "status",
          "steps",
          "errors",
          "requestId",
          "timestamp",
          "apiVersion"
        ]
      },
      "Step": {
        "type": "object",
        "properties": {
          "stepId": {
            "type": "string"
          },
          "parentStepId": {
            "type": "string",
            "nullable": true
          },
          "stepType": {
            "type": "string",
            "enum": [
              "REASONING",
              "QUERY",
              "PREPARE_ANSWER"
            ]
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "finished",
              "failed"
            ]
          },
          "contentType": {
            "type": "string",
            "enum": [
              "TEXT",
              "JSON",
              "MARKDOWN"
            ]
          },
          "content": {},
          "startTime": {
            "type": "integer"
          },
          "endTime": {
            "type": "integer",
            "nullable": true
          },
          "costTime": {
            "type": "integer",
            "nullable": true
          }
        },
        "required": [
          "stepId",
          "stepType",
          "title",
          "status",
          "contentType"
        ]
      },
      "Ask": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "form",
              "natural_language"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "fill_params",
              "confirm_params"
            ]
          },
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "parameters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Parameter"
            }
          },
          "reportContext": {
            "type": "object",
            "properties": {
              "templateInstance": {
                "$ref": "#/components/schemas/TemplateInstance"
              }
            }
          }
        },
        "required": [
          "mode",
          "type",
          "title",
          "text"
        ]
      },
      "Parameter": {
        "$ref": "../report_system/schemas/report-template.schema.json#/$defs/Parameter"
      },
      "AnswerEnvelope": {
        "type": "object",
        "properties": {
          "answerType": {
            "type": "string",
            "enum": [
              "TEXT",
              "REPORT",
              "REPORT_TEMPLATE"
            ]
          },
          "answer": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/components/schemas/ReportAnswer"
              },
              {
                "$ref": "#/components/schemas/ReportTemplateExtractionResult"
              }
            ]
          }
        },
        "required": [
          "answerType",
          "answer"
        ]
      },
      "ReportAnswer": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "generating",
              "available",
              "failed"
            ]
          },
          "report": {
